@model  About
@{
    ViewData["Title"] = "UpdateAbout";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card">
    <div class="card-body">
        <div class="d-flex align-items-center">
            <h5 class="mb-0">Hakkımızda Yazısı Güncelleme Sayfası</h5>
        </div>
        <form method="post">
            <input type="hidden" asp-for="AboutId"/>
            <div class="form-group">
                <label>Başlık</label>
                <input type="text" class="form-control" asp-for="Title" placeholder="Başlığı Giriniz" />
            </div>
            <div class="form-group">
                <label>Açıklama</label>
                <textarea class="form-control" asp-for="Description" placeholder="Açıklamayı Giriniz"></textarea>
            </div>
            <div class="form-group">
                <label>Resim</label>
                <input type="text" class="form-control" rows="5" asp-for="ImageURL" placeholder="Resim Yolunu Giriniz" />
            </div>
            <button type="submit" class="btn btn-outline-success mt-3">Güncelle</button>
        </form>
    </div>
</div>

