@model List<TrailerVideo>
@{
    ViewData["Title"] = "TrailerVideoList";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    int count = 0;
}

<style>
    .video-card {
        background: linear-gradient(145deg, #1a1a2e 0%, #16213e 60%, #0f3460 100%);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 20px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.3), 0 0 0 1px rgba(255,255,255,0.02);
        overflow: hidden;
        position: relative;
    }

        .video-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(249,115,22,0.45), transparent);
        }

    .video-card-body {
        padding: 1.5rem 1.75rem;
    }

    /* Header */
    .video-page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .video-title-group {
        display: flex;
        align-items: center;
        gap: 0.7rem;
    }

    .video-title-icon {
        width: 38px;
        height: 38px;
        border-radius: 11px;
        background: rgba(249,115,22,0.1);
        border: 1px solid rgba(249,115,22,0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fb923c;
        font-size: 1rem;
    }

    .video-title-group h5 {
        font-size: 0.95rem;
        font-weight: 700;
        color: #e8e8f0;
        margin: 0;
    }

    .video-count-badge {
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.07em;
        text-transform: uppercase;
        background: rgba(249,115,22,0.1);
        color: #fb923c;
        border: 1px solid rgba(249,115,22,0.2);
        padding: 2px 9px;
        border-radius: 20px;
    }

    /* Search */
    .search-wrap {
        position: relative;
        display: flex;
        align-items: center;
    }

    .search-icon-inner {
        position: absolute;
        left: 12px;
        color: rgba(255,255,255,0.3);
        font-size: 0.8rem;
        pointer-events: none;
    }

    .search-input {
        background: rgba(255,255,255,0.04) !important;
        border: 1px solid rgba(255,255,255,0.09) !important;
        border-radius: 10px !important;
        color: #e8e8f0 !important;
        padding: 0.5rem 1rem 0.5rem 2.2rem !important;
        font-size: 0.8rem !important;
        width: 220px;
        transition: all 0.2s ease;
    }

        .search-input::placeholder {
            color: rgba(255,255,255,0.25) !important;
        }

        .search-input:focus {
            outline: none !important;
            border-color: rgba(249,115,22,0.35) !important;
            box-shadow: 0 0 0 3px rgba(249,115,22,0.06) !important;
            background: rgba(255,255,255,0.06) !important;
            width: 260px;
        }

    /* Table */
    .video-table {
        width: 100%;
        border-collapse: collapse;
        font-family: 'Segoe UI', sans-serif;
    }

        .video-table thead tr {
            border-bottom: 1px solid rgba(255,255,255,0.06);
        }

        .video-table thead th {
            padding: 0.6rem 1rem;
            font-size: 0.67rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: rgba(255,255,255,0.3);
            white-space: nowrap;
        }

        .video-table tbody tr {
            border-bottom: 1px solid rgba(255,255,255,0.04);
            transition: background 0.15s ease;
        }

            .video-table tbody tr:last-child {
                border-bottom: none;
            }

            .video-table tbody tr:hover {
                background: rgba(255,255,255,0.025);
            }

        .video-table tbody td {
            padding: 0.9rem 1rem;
            font-size: 0.82rem;
            color: rgba(255,255,255,0.6);
            vertical-align: middle;
        }

    /* Row num */
    .row-num {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 26px;
        height: 24px;
        padding: 0 6px;
        background: rgba(255,255,255,0.05);
        border-radius: 6px;
        font-size: 0.7rem;
        font-weight: 700;
        color: rgba(255,255,255,0.35);
    }

    /* Title cell */
    .title-cell {
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }

    .play-icon-mini {
        width: 32px;
        height: 32px;
        border-radius: 9px;
        background: rgba(249,115,22,0.08);
        border: 1px solid rgba(249,115,22,0.15);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fb923c;
        font-size: 0.75rem;
        flex-shrink: 0;
        transition: all 0.2s;
    }

    .video-table tbody tr:hover .play-icon-mini {
        background: rgba(249,115,22,0.15);
        border-color: rgba(249,115,22,0.3);
    }

    .title-text {
        font-weight: 600;
        color: #d8d8e8;
        font-size: 0.83rem;
    }

    /* Actions */
    .action-group {
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    .action-btn {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
        text-decoration: none;
        border: 1px solid transparent;
        transition: all 0.2s ease;
    }

        .action-btn.watch {
            color: #fb923c;
            background: rgba(249,115,22,0.08);
            border-color: rgba(249,115,22,0.15);
        }

            .action-btn.watch:hover {
                background: rgba(249,115,22,0.18);
                border-color: rgba(249,115,22,0.35);
                transform: translateY(-1px);
            }

        .action-btn.edit {
            color: #fbbf24;
            background: rgba(251,191,36,0.08);
            border-color: rgba(251,191,36,0.15);
        }

            .action-btn.edit:hover {
                background: rgba(251,191,36,0.18);
                border-color: rgba(251,191,36,0.35);
                transform: translateY(-1px);
            }

        .action-btn.delete {
            color: #f87171;
            background: rgba(248,113,113,0.08);
            border-color: rgba(248,113,113,0.15);
        }

            .action-btn.delete:hover {
                background: rgba(248,113,113,0.18);
                border-color: rgba(248,113,113,0.35);
                transform: translateY(-1px);
            }

    /* Footer */
    .table-footer-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.75rem;
        padding-top: 1.25rem;
        margin-top: 0.25rem;
        border-top: 1px solid rgba(255,255,255,0.05);
    }

    .table-footer-info {
        font-size: 0.7rem;
        color: rgba(255,255,255,0.25);
    }

        .table-footer-info span {
            color: rgba(255,255,255,0.45);
            font-weight: 600;
        }

    .btn-add-video {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 0.55rem 1.1rem;
        font-size: 0.78rem;
        font-weight: 600;
        color: #1a0c05;
        background: linear-gradient(135deg, #fb923c, #f97316);
        border: none;
        border-radius: 10px;
        text-decoration: none;
        transition: all 0.2s ease;
        box-shadow: 0 3px 14px rgba(249,115,22,0.25);
    }

        .btn-add-video:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(249,115,22,0.38);
            color: #1a0c05;
        }

    /* Empty / no-result */
    .empty-state {
        padding: 3rem;
        text-align: center;
        color: rgba(255,255,255,0.2);
        font-size: 0.82rem;
    }

    .no-result-row {
        display: none;
    }

        .no-result-row td {
            text-align: center !important;
            padding: 2rem !important;
            color: rgba(255,255,255,0.25) !important;
            font-size: 0.8rem;
        }
</style>

<div class="video-card">
    <div class="video-card-body">

        <!-- Header -->
        <div class="video-page-header">
            <div class="video-title-group">
                <div class="video-title-icon">
                    <i class="bi bi-play-btn-fill"></i>
                </div>
                <h5>Trailer Video Listesi</h5>
                <span class="video-count-badge">@Model?.Count video</span>
            </div>

            <div class="search-wrap">
                <i class="bi bi-search search-icon-inner"></i>
                <input class="form-control search-input"
                       id="videoSearch"
                       type="text"
                       placeholder="Video başlığı ara..." />
            </div>
        </div>

        <!-- Table -->
        <div class="table-responsive">
            @if (Model != null && Model.Any())
            {
                <table class="video-table" id="videoTable">
                    <thead>
                        <tr>
                            <th style="width:46px;">#</th>
                            <th>Başlık</th>
                            <th style="width:110px; text-align:right; padding-right:1.1rem;">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            count++;
                            <tr class="video-row">
                                <td><span class="row-num">@count</span></td>
                                <td>
                                    <div class="title-cell">
                                        <div class="play-icon-mini">
                                            <i class="bi bi-play-fill"></i>
                                        </div>
                                        <span class="title-text video-title-val">@item.Title</span>
                                    </div>
                                </td>
                                <td style="text-align:right;">
                                    <div class="action-group justify-content-end">
                                        <a href="/TrailerVideo/UpdateTrailerVideo/@item.TrailerVideoId"
                                           class="action-btn watch"
                                           title="Videoyu Gör"
                                           data-bs-toggle="tooltip" data-bs-placement="top">
                                            <i class="bi bi-eye-fill"></i>
                                        </a>
                                        <a href="/TrailerVideo/UpdateTrailerVideo/@item.TrailerVideoId"
                                           class="action-btn edit"
                                           title="Düzenle"
                                           data-bs-toggle="tooltip" data-bs-placement="top">
                                            <i class="bi bi-pencil-fill"></i>
                                        </a>
                                        <a href="/TrailerVideo/DeleteTrailerVideo/@item.TrailerVideoId"
                                           class="action-btn delete"
                                           title="Sil"
                                           data-bs-toggle="tooltip" data-bs-placement="top"
                                           onclick="return confirm('Bu videoyu silmek istediğinize emin misiniz?')">
                                            <i class="bi bi-trash-fill"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                        <tr class="no-result-row" id="noResultRow">
                            <td colspan="3">
                                <div style="font-size:1.5rem; margin-bottom:.4rem;">🔍</div>
                                Aradığınız video bulunamadı.
                            </td>
                        </tr>
                    </tbody>
                </table>
            }
            else
            {
                <div class="empty-state">
                    <div style="font-size:2.2rem; margin-bottom:.6rem;">🎬</div>
                    Henüz video eklenmemiş.
                </div>
            }
        </div>

        <!-- Footer -->
        <div class="table-footer-row">
            <span class="table-footer-info">
                Toplam <span id="visibleCount">@Model?.Count</span> video gösteriliyor
            </span>
            <a href="/TrailerVideo/CreateTrailerVideo/" class="btn-add-video">
                <i class="bi bi-plus-lg"></i>
                Yeni Video Ekle
            </a>
        </div>

    </div>
</div>

<script>
    document.getElementById('videoSearch')?.addEventListener('input', function () {
        const q = this.value.toLowerCase().trim();
        const rows = document.querySelectorAll('.video-row');
        const noResult = document.getElementById('noResultRow');
        let visible = 0;

        rows.forEach(row => {
            const title = row.querySelector('.video-title-val')?.textContent.toLowerCase() || '';
            const show  = !q || title.includes(q);
            row.style.display = show ? '' : 'none';
            if (show) visible++;
        });

        noResult.style.display = visible === 0 && q.length > 0 ? '' : 'none';
        document.getElementById('visibleCount').textContent = visible;
    });

    document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(el => {
        new bootstrap.Tooltip(el);
    });
</script>
