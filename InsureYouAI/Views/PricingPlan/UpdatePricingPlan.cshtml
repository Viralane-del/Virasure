@model PricingPlan
@{
    ViewData["Title"] = "UpdatePricingPlan";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card">
    <div class="card-body">
        <div class="d-flex align-items-center">
            <h5 class="mb-0">Ödeme Planı Güncelleme Sayfası</h5>
        </div>
        <form method="post">
            <input  type="hidden" asp-for="PricingPlanId" />
            <div class="form-group">
                <label>Başlık</label>
                <input type="text" class="form-control" asp-for="Title" />
            </div>
            <div class="form-group">
                <label>Fiyat</label>
                <input type="text" class="form-control" asp-for="Price" />
            </div>
            <button type="submit" class="btn btn-success mt-3">Ödeme Planını GÜncelle</button>
        </form>
    </div>
</div>

