@model Article
<div class="details__content pb-30">
    <h2>
        @Model.Title
    </h2>
    <div class="meta-info">
        <ul>
            <li><i class="fas fa-user"></i> Yazar: @Model.AppUser.Name @Model.AppUser.Surname </li>
            <li><i class="fal fa-comments"></i> @ViewBag.commentCount Yorum</li>
            <li><i class="fas fa-tags"></i> Kategori: @Model.Category.CategoryName</li>
            <li><i class="fal fa-calendar-alt"></i> @Model.CreatedDate.ToString("dd-MMM-yyyy")</li>
        </ul>
    </div>
    <div class="blog-content">
        @Html.Raw(Model.Content)
    </div> 
</div>
<style>
    .blog-content p {
        margin-bottom: 20px;
        line-height: 1.8;
    }

    .blog-content h2,
    .blog-content h3,
    .blog-content h4 {
        margin: 30px 0 15px;
        font-weight: 700;
    }

    .blog-content ul {
        padding-left: 20px;
        margin-bottom: 20px;
    }

    .blog-content img {
        max-width: 100%;
        border-radius: 10px;
        margin: 30px 0;
    }
</style>