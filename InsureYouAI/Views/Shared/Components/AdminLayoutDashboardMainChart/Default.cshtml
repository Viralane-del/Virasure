@model RevenueExpenseChartViewModel

<style>
    .revenue-card {
        background: linear-gradient(145deg, #1a1a2e 0%, #16213e 60%, #0f3460 100%);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 20px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.3), 0 0 0 1px rgba(255,255,255,0.02);
        overflow: hidden;
        position: relative;
    }

        .revenue-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
        }

    .revenue-header {
        padding: 1.4rem 1.6rem 0;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .revenue-title-group {
        display: flex;
        align-items: center;
        gap: 0.65rem;
    }

    .revenue-title-icon {
        width: 34px;
        height: 34px;
        border-radius: 10px;
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.08);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 15px;
    }

    .revenue-title-text {
        font-size: 0.88rem;
        font-weight: 600;
        color: #e8e8f0;
        letter-spacing: 0.01em;
        margin: 0;
    }

    .revenue-menu-btn {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.07);
        display: flex;
        align-items: center;
        justify-content: center;
        color: rgba(255,255,255,0.4);
        cursor: pointer;
        transition: all 0.2s;
    }

        .revenue-menu-btn:hover {
            background: rgba(255,255,255,0.08);
            color: rgba(255,255,255,0.7);
        }

    .revenue-divider {
        margin: 1.1rem 0 0;
        border: none;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.07), transparent);
    }

    .revenue-stats-row {
        padding: 1.1rem 1.6rem 0.5rem;
        display: flex;
        align-items: stretch;
        gap: 0;
    }

    .revenue-stat-block {
        flex: 1;
        padding: 0.75rem 1.2rem;
        border-radius: 12px;
        position: relative;
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
    }

        .revenue-stat-block.income-block {
            background: rgba(34,197,94,0.07);
            border: 1px solid rgba(34,197,94,0.15);
            margin-right: 0.5rem;
        }

        .revenue-stat-block.expense-block {
            background: rgba(239,68,68,0.07);
            border: 1px solid rgba(239,68,68,0.15);
        }

    .stat-block-label {
        font-size: 0.67rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.09em;
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .income-block .stat-block-label {
        color: rgba(74,222,128,0.7);
    }

    .expense-block .stat-block-label {
        color: rgba(248,113,113,0.7);
    }

    .stat-block-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
    }

    .income-block .stat-block-dot {
        background: #4ade80;
        box-shadow: 0 0 6px rgba(74,222,128,0.6);
    }

    .expense-block .stat-block-dot {
        background: #f87171;
        box-shadow: 0 0 6px rgba(248,113,113,0.6);
    }

    .stat-block-amount {
        font-size: 1.45rem;
        font-weight: 700;
        font-variant-numeric: tabular-nums;
        letter-spacing: -0.02em;
        line-height: 1.1;
    }

    .income-block .stat-block-amount {
        color: #4ade80;
    }

    .expense-block .stat-block-amount {
        color: #f87171;
    }

    .stat-block-sub {
        font-size: 0.68rem;
        color: rgba(255,255,255,0.25);
    }

    .revenue-chart-area {
        padding: 0.75rem 1.2rem 1.2rem;
    }

    .chart-container {
        position: relative;
        height: 280px;
    }

    .revenue-footer {
        padding: 0.85rem 1.6rem;
        border-top: 1px solid rgba(255,255,255,0.05);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .revenue-footer-note {
        font-size: 0.68rem;
        color: rgba(255,255,255,0.25);
        display: flex;
        align-items: center;
        gap: 5px;
    }

        .revenue-footer-note i {
            color: #4ade80;
            font-size: 0.65rem;
        }

    .revenue-footer-link {
        font-size: 0.7rem;
        font-weight: 600;
        color: rgba(255,255,255,0.3);
        text-decoration: none;
        letter-spacing: 0.04em;
        transition: color 0.2s;
    }

        .revenue-footer-link:hover {
            color: rgba(255,255,255,0.6);
        }
</style>

<div class="col-12 col-lg-12 col-xl-12 d-flex">
    <div class="revenue-card w-100">

        <div class="revenue-header">
            <div class="revenue-title-group">
                <div class="revenue-title-icon">💹</div>
                <h6 class="revenue-title-text">Sigorta Satış ve Ödeme Grafiği</h6>
            </div>
            <div class="dropdown">
                <div class="revenue-menu-btn dropdown-toggle dropdown-toggle-nocaret"
                     data-bs-toggle="dropdown">
                    <i class="bi bi-three-dots" style="font-size:0.85rem;"></i>
                </div>
                <ul class="dropdown-menu dropdown-menu-end dropdown-menu-dark"
                    style="background:#1e2235; border:1px solid rgba(255,255,255,0.08); border-radius:12px; font-size:0.8rem;">
                    <li><a class="dropdown-item" href="#">Bu Hafta</a></li>
                    <li><a class="dropdown-item" href="#">Bu Ay</a></li>
                    <li><a class="dropdown-item" href="#">Bu Yıl</a></li>
                    <li><hr class="dropdown-divider" style="border-color:rgba(255,255,255,0.06);"></li>
                    <li><a class="dropdown-item" href="#">Raporu İndir</a></li>
                </ul>
            </div>
        </div>

        <hr class="revenue-divider" />

        <div class="revenue-stats-row">
            <div class="revenue-stat-block income-block">
                <div class="stat-block-label">
                    <span class="stat-block-dot"></span>
                    Gelen Tutar
                </div>
                <div class="stat-block-amount">₺ @ViewBag.v1</div>
                <div class="stat-block-sub">Toplam prim geliri</div>
            </div>
            <div class="revenue-stat-block expense-block">
                <div class="stat-block-label">
                    <span class="stat-block-dot"></span>
                    Giden Tutar
                </div>
                <div class="stat-block-amount">₺ @ViewBag.v2</div>
                <div class="stat-block-sub">Toplam hasar ödemesi</div>
            </div>
        </div>

        <div class="revenue-chart-area">
            <div class="chart-container">
                <canvas id="revenueExpenseChart"></canvas>
            </div>
        </div>

        <div class="revenue-footer">
            <span class="revenue-footer-note">
                <i class="bi bi-circle-fill" style="font-size:6px;"></i>
                Son 12 aylık veriler gösteriliyor
            </span>
            <a href="#" class="revenue-footer-link">Tüm Rapor →</a>
        </div>

    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const months        = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.Months));
        const revenueTotals = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.RevenueTotals));
        const expenseTotals = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.ExpenseTotals));

        const ctx = document.getElementById('revenueExpenseChart').getContext('2d');

        /* Gradient fill for income line */
        const incomeGradient = ctx.createLinearGradient(0, 0, 0, 280);
        incomeGradient.addColorStop(0,   'rgba(74, 222, 128, 0.25)');
        incomeGradient.addColorStop(0.6, 'rgba(74, 222, 128, 0.05)');
        incomeGradient.addColorStop(1,   'rgba(74, 222, 128, 0)');

        const expenseGradient = ctx.createLinearGradient(0, 0, 0, 280);
        expenseGradient.addColorStop(0,   'rgba(248, 113, 113, 0.18)');
        expenseGradient.addColorStop(0.6, 'rgba(248, 113, 113, 0.04)');
        expenseGradient.addColorStop(1,   'rgba(248, 113, 113, 0)');

        new Chart(ctx, {
            type: 'line',
            data: {
                labels: months,
                datasets: [
                    {
                        label: "Gelir",
                        data: revenueTotals,
                        fill: true,
                        borderColor: "#4ade80",
                        backgroundColor: incomeGradient,
                        tension: 0.45,
                        borderWidth: 2.5,
                        pointBackgroundColor: "#4ade80",
                        pointBorderColor: "#0f3460",
                        pointBorderWidth: 2,
                        pointRadius: 4,
                        pointHoverRadius: 6,
                        pointHoverBackgroundColor: "#4ade80",
                        pointHoverBorderColor: "#fff",
                        pointHoverBorderWidth: 2
                    },
                    {
                        label: "Gider",
                        data: expenseTotals,
                        fill: true,
                        borderColor: "#f87171",
                        backgroundColor: expenseGradient,
                        borderDash: [6, 4],
                        tension: 0.45,
                        borderWidth: 2.5,
                        pointBackgroundColor: "#f87171",
                        pointBorderColor: "#0f3460",
                        pointBorderWidth: 2,
                        pointRadius: 4,
                        pointHoverRadius: 6,
                        pointHoverBackgroundColor: "#f87171",
                        pointHoverBorderColor: "#fff",
                        pointHoverBorderWidth: 2
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                interaction: {
                    mode: 'index',
                    intersect: false
                },
                plugins: {
                    legend: {
                        display: true,
                        position: 'top',
                        align: 'end',
                        labels: {
                            color: 'rgba(255,255,255,0.45)',
                            font: { size: 11, weight: '600' },
                            boxWidth: 10,
                            boxHeight: 10,
                            borderRadius: 3,
                            usePointStyle: true,
                            pointStyle: 'circle',
                            padding: 16
                        }
                    },
                    tooltip: {
                        backgroundColor: 'rgba(15, 20, 45, 0.95)',
                        borderColor: 'rgba(255,255,255,0.08)',
                        borderWidth: 1,
                        titleColor: 'rgba(255,255,255,0.7)',
                        bodyColor: 'rgba(255,255,255,0.55)',
                        padding: 12,
                        cornerRadius: 10,
                        titleFont: { size: 11, weight: '700' },
                        bodyFont: { size: 12, weight: '600' },
                        callbacks: {
                            label: function(ctx) {
                                return '  ' + ctx.dataset.label + ': ₺' + ctx.parsed.y.toLocaleString('tr-TR');
                            }
                        }
                    }
                },
                scales: {
                    x: {
                        grid: {
                            color: 'rgba(255,255,255,0.04)',
                            drawBorder: false
                        },
                        ticks: {
                            color: 'rgba(255,255,255,0.3)',
                            font: { size: 10, weight: '600' },
                            maxRotation: 0
                        },
                        border: { display: false }
                    },
                    y: {
                        beginAtZero: true,
                        grid: {
                            color: 'rgba(255,255,255,0.04)',
                            drawBorder: false
                        },
                        ticks: {
                            color: 'rgba(255,255,255,0.3)',
                            font: { size: 10 },
                            callback: function(value) {
                                if (value >= 1000) return '₺' + (value / 1000).toFixed(0) + 'K';
                                return '₺' + value;
                            },
                            padding: 8
                        },
                        border: { display: false }
                    }
                }
            }
        });
    });
</script>
