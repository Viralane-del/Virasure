@model List<PolicyGroupViewModel>
@{
    int total = ViewBag.TotalPolicyCount;
}
@functions {
    string GetEmoji(string policyType)
    {
        return policyType switch
        {
            "Egitim" => "🎓",
            "Kasko" => "🚗",
            "Konut" => "🏠",
            "Saglik" => "🩺",
            "Trafik" => "🚦",
            "Evcil Hayvan" => "🐾",
            "Seyahat" => "✈️",
            _ => "📄"
        };
    }

    string GetAccentColor(int index)
    {
        string[] colors = {
            "#3b82f6", "#22c55e", "#f59e0b",
            "#a855f7", "#ec4899", "#14b8a6", "#f97316"
        };
        return colors[index % colors.Length];
    }
}

<style>
    .policy-card {
        background: linear-gradient(145deg, #1a1a2e 0%, #16213e 60%, #0f3460 100%);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 20px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.3), 0 0 0 1px rgba(255,255,255,0.02);
        overflow: hidden;
        position: relative;
    }

        .policy-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
        }

    .policy-card-header {
        padding: 1.4rem 1.6rem 0;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .policy-card-title {
        display: flex;
        align-items: center;
        gap: 0.65rem;
    }

    .policy-title-icon {
        width: 34px;
        height: 34px;
        border-radius: 10px;
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.08);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 15px;
    }

    .policy-title-text {
        font-size: 0.88rem;
        font-weight: 600;
        color: #e8e8f0;
        letter-spacing: 0.01em;
        margin: 0;
    }

    .policy-menu-btn {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.07);
        display: flex;
        align-items: center;
        justify-content: center;
        color: rgba(255,255,255,0.4);
        cursor: pointer;
        transition: all 0.2s;
    }

        .policy-menu-btn:hover {
            background: rgba(255,255,255,0.08);
            color: rgba(255,255,255,0.7);
        }

    .policy-divider {
        margin: 1.1rem 0 0;
        border: none;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.07), transparent);
    }

    .policy-list {
        padding: 0.5rem 1.4rem 0.75rem;
        max-height: 340px;
        overflow-y: auto;
        scrollbar-width: thin;
        scrollbar-color: rgba(255,255,255,0.1) transparent;
    }

        .policy-list::-webkit-scrollbar {
            width: 3px;
        }

        .policy-list::-webkit-scrollbar-track {
            background: transparent;
        }

        .policy-list::-webkit-scrollbar-thumb {
            background: rgba(255,255,255,0.1);
            border-radius: 4px;
        }

    .policy-row {
        display: flex;
        align-items: center;
        gap: 0.9rem;
        padding: 0.85rem 0;
        border-bottom: 1px solid rgba(255,255,255,0.04);
        transition: opacity 0.2s;
    }

        .policy-row:last-child {
            border-bottom: none;
        }

        .policy-row:hover {
            opacity: 0.85;
        }

    .policy-emoji-box {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.07);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        flex-shrink: 0;
        transition: transform 0.2s;
    }

    .policy-row:hover .policy-emoji-box {
        transform: scale(1.08);
    }

    .policy-info {
        flex: 1;
        min-width: 0;
    }

    .policy-meta {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        margin-bottom: 0.45rem;
    }

    .policy-name {
        font-size: 0.82rem;
        font-weight: 600;
        color: #d8d8e8;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .policy-stats {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-shrink: 0;
        margin-left: 0.5rem;
    }

    .policy-count-badge {
        font-size: 0.68rem;
        font-weight: 600;
        color: rgba(255,255,255,0.35);
        background: rgba(255,255,255,0.05);
        border-radius: 6px;
        padding: 2px 7px;
        white-space: nowrap;
    }

    .policy-pct {
        font-size: 0.78rem;
        font-weight: 700;
        font-variant-numeric: tabular-nums;
        min-width: 36px;
        text-align: right;
    }

    .policy-bar-track {
        height: 5px;
        background: rgba(255,255,255,0.06);
        border-radius: 99px;
        overflow: hidden;
    }

    .policy-bar-fill {
        height: 100%;
        border-radius: 99px;
        transition: width 0.6s cubic-bezier(0.4,0,0.2,1);
        position: relative;
    }

        .policy-bar-fill::after {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            width: 6px;
            height: 100%;
            background: rgba(255,255,255,0.35);
            border-radius: 99px;
            filter: blur(2px);
        }

    .policy-card-footer {
        padding: 0.85rem 1.6rem;
        border-top: 1px solid rgba(255,255,255,0.05);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .footer-total {
        font-size: 0.7rem;
        color: rgba(255,255,255,0.28);
    }

        .footer-total strong {
            color: rgba(255,255,255,0.5);
            font-weight: 700;
        }

    .footer-link {
        font-size: 0.7rem;
        font-weight: 600;
        color: rgba(255,255,255,0.3);
        text-decoration: none;
        letter-spacing: 0.04em;
        transition: color 0.2s;
    }

        .footer-link:hover {
            color: rgba(255,255,255,0.6);
        }
</style>

<div class="col-12 col-lg-6 col-xl-6 d-flex">
    <div class="policy-card w-100">

        <div class="policy-card-header">
            <div class="policy-card-title">
                <div class="policy-title-icon">📊</div>
                <h6 class="policy-title-text">En Çok Satılan Poliçelerimiz</h6>
            </div>
            <div class="dropdown">
                <div class="policy-menu-btn dropdown-toggle dropdown-toggle-nocaret"
                     data-bs-toggle="dropdown">
                    <i class="bi bi-three-dots" style="font-size:0.85rem;"></i>
                </div>
                <ul class="dropdown-menu dropdown-menu-end dropdown-menu-dark"
                    style="background:#1e2235; border:1px solid rgba(255,255,255,0.08); border-radius:12px; font-size:0.8rem;">
                    <li><a class="dropdown-item" href="#">Bu Hafta</a></li>
                    <li><a class="dropdown-item" href="#">Bu Ay</a></li>
                    <li><hr class="dropdown-divider" style="border-color:rgba(255,255,255,0.06);"></li>
                    <li><a class="dropdown-item" href="#">Tümünü Gör</a></li>
                </ul>
            </div>
        </div>

        <hr class="policy-divider" />

        <div class="policy-list">
            @{
                int idx = 0;
            }
            @foreach (var item in Model)
            {
                var percentage = total > 0 ? (int)Math.Round((double)item.Count / total * 100) : 0;
                var color = GetAccentColor(idx);
                <div class="policy-row">
                    <div class="policy-emoji-box">@GetEmoji(item.PolicyType)</div>
                    <div class="policy-info">
                        <div class="policy-meta">
                            <span class="policy-name">@item.PolicyType</span>
                            <div class="policy-stats">
                                <span class="policy-count-badge">@item.Count satış</span>
                                <span class="policy-pct" style="color:@color;">@percentage%</span>
                            </div>
                        </div>
                        @{
                            var colorFaded = color + "66";
                            var barStyle = $"width:{percentage}%; background: linear-gradient(90deg, {colorFaded}, {color});";
                        }
                        <div class="policy-bar-track">
                            <div class="policy-bar-fill" style="@barStyle"></div>
                        </div>
                    </div>
                </div>
                idx++;
            }
        </div>

        <div class="policy-card-footer">
            <span class="footer-total">Toplam <strong>@total</strong> poliçe satışı</span>
            <a href="#" class="footer-link">Raporları Gör →</a>
        </div>

    </div>
</div>

