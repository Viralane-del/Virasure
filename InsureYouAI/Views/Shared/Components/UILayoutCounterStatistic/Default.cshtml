
<div class="counter-area p-relative ">
    <div class="container pt-50 pb-50">

        <div class="row p-relative">
            <div class="col-lg-3 col-md-6 col-sm-12">
                <div class="single-counter" data-aos="fade-up" data-aos-duration="1000">
                    <div class="counter p-relative">
                        <span class="count">@ViewBag.categoryCount</span>
                        <p>Sigorta Kategori <br>Sayımız</p>
                    </div>

                </div>
            </div>
            <div class="col-lg-3 col-md-6 col-sm-12">
                <div class="single-counter" data-aos="fade-up" data-aos-duration="1300">
                    <div class="counter p-relative">
                        <span class="count">@ViewBag.serviceCount</span>
                        <p>Sağladığımız<br>Hizmet Sayısı</p>
                    </div>

                </div>
            </div>
            <div class="col-lg-3 col-md-6 col-sm-12">
                <div class="single-counter" data-aos="fade-up" data-aos-duration="1600">
                    <div class="counter p-relative">
                        <span class="count">@ViewBag.userCount</span>
                        <p>Bize Güvenen<br>Kullanıcılarımız</p>
                    </div>

                </div>
            </div>
            <div class="col-lg-3 col-md-6 col-sm-12">
                <div class="single-counter" data-aos="fade-up" data-aos-duration="1900">
                    <div class="counter p-relative">
                        <span class="count">@ViewBag.articleCount</span>
                        <p>Akılda ki Soruları Cevaplattıran<br>AI Makalelerimiz</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
