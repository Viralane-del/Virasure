@model List<Comment>

<style>
    .comments-card {
        background: linear-gradient(145deg, #1a1a2e 0%, #16213e 60%, #0f3460 100%);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 20px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.3), 0 0 0 1px rgba(255,255,255,0.02);
        overflow: hidden;
        position: relative;
    }

        .comments-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(251,191,36,0.4), transparent);
        }

    .comments-card-header {
        padding: 1.4rem 1.6rem 0;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .comments-title-group {
        display: flex;
        align-items: center;
        gap: 0.65rem;
    }

    .comments-title-icon {
        width: 34px;
        height: 34px;
        border-radius: 10px;
        background: rgba(251,191,36,0.1);
        border: 1px solid rgba(251,191,36,0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 15px;
    }

    .comments-title-text {
        font-size: 0.88rem;
        font-weight: 600;
        color: #e8e8f0;
        letter-spacing: 0.01em;
        margin: 0;
    }

    .comments-menu-btn {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.07);
        display: flex;
        align-items: center;
        justify-content: center;
        color: rgba(255,255,255,0.4);
        cursor: pointer;
        transition: all 0.2s;
    }

        .comments-menu-btn:hover {
            background: rgba(255,255,255,0.08);
            color: rgba(255,255,255,0.7);
        }

    .comments-divider {
        margin: 1.1rem 0 0;
        border: none;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.07), transparent);
    }

    .comments-list {
        padding: 0.25rem 1.4rem 0.5rem;
        max-height: 400px;
        overflow-y: auto;
        scrollbar-width: thin;
        scrollbar-color: rgba(255,255,255,0.1) transparent;
    }

        .comments-list::-webkit-scrollbar {
            width: 3px;
        }

        .comments-list::-webkit-scrollbar-track {
            background: transparent;
        }

        .comments-list::-webkit-scrollbar-thumb {
            background: rgba(255,255,255,0.1);
            border-radius: 4px;
        }

    .comment-row {
        display: flex;
        align-items: flex-start;
        gap: 0.85rem;
        padding: 1rem 0;
        border-bottom: 1px solid rgba(255,255,255,0.04);
        transition: opacity 0.2s;
    }

        .comment-row:last-child {
            border-bottom: none;
        }

        .comment-row:hover {
            opacity: 0.9;
        }

    .comment-avatar-wrap {
        position: relative;
        flex-shrink: 0;
    }

    .comment-avatar {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        object-fit: cover;
        border: 2px solid rgba(255,255,255,0.07);
    }

    .comment-avatar-fallback {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        background: linear-gradient(135deg, rgba(251,191,36,0.25), rgba(251,191,36,0.08));
        border: 1px solid rgba(251,191,36,0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.8rem;
        font-weight: 700;
        color: #fbbf24;
    }

    .comment-body {
        flex: 1;
        min-width: 0;
    }

    .comment-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 0.5rem;
        margin-bottom: 0.3rem;
    }

    .comment-name {
        font-size: 0.82rem;
        font-weight: 700;
        color: #e8e8f0;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .comment-date {
        font-size: 0.65rem;
        color: rgba(255,255,255,0.25);
        white-space: nowrap;
        flex-shrink: 0;
        padding-top: 1px;
    }

    .comment-article {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-size: 0.67rem;
        font-weight: 600;
        color: rgba(255,255,255,0.3);
        background: rgba(255,255,255,0.05);
        border-radius: 5px;
        padding: 2px 7px;
        margin-bottom: 0.4rem;
        max-width: 100%;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .comment-stars {
        display: flex;
        gap: 2px;
        margin-bottom: 0.35rem;
    }

        .comment-stars i {
            font-size: 0.7rem;
            color: #fbbf24;
        }

    .comment-text {
        font-size: 0.78rem;
        color: rgba(255,255,255,0.45);
        line-height: 1.55;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        margin: 0;
    }

    .comments-footer {
        padding: 0.85rem 1.6rem;
        border-top: 1px solid rgba(255,255,255,0.05);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .comments-footer-note {
        font-size: 0.68rem;
        color: rgba(255,255,255,0.25);
    }

        .comments-footer-note span {
            color: rgba(255,255,255,0.45);
            font-weight: 600;
        }

    .comments-footer-link {
        font-size: 0.7rem;
        font-weight: 600;
        color: rgba(255,255,255,0.3);
        text-decoration: none;
        letter-spacing: 0.04em;
        transition: color 0.2s;
    }

        .comments-footer-link:hover {
            color: rgba(255,255,255,0.6);
        }
</style>

<div class="col-12 col-lg-6 col-xl-6 d-flex">
    <div class="comments-card w-100">

        <div class="comments-card-header">
            <div class="comments-title-group">
                <div class="comments-title-icon">💬</div>
                <h6 class="comments-title-text">Müşteri Yorumları</h6>
            </div>
            <div class="dropdown">
                <div class="comments-menu-btn dropdown-toggle dropdown-toggle-nocaret"
                     data-bs-toggle="dropdown">
                    <i class="bi bi-three-dots" style="font-size:0.85rem;"></i>
                </div>
                <ul class="dropdown-menu dropdown-menu-end dropdown-menu-dark"
                    style="background:#1e2235; border:1px solid rgba(255,255,255,0.08); border-radius:12px; font-size:0.8rem;">
                    <li><a class="dropdown-item" href="#">En Yeni</a></li>
                    <li><a class="dropdown-item" href="#">En Yüksek Puan</a></li>
                    <li><hr class="dropdown-divider" style="border-color:rgba(255,255,255,0.06);"></li>
                    <li><a class="dropdown-item" href="#">Tümünü Gör</a></li>
                </ul>
            </div>
        </div>

        <hr class="comments-divider" />

        <div class="comments-list">
            @foreach (var item in Model)
            {
                var initials = (item.AppUser?.Name?.Length > 0 ? item.AppUser.Name[0].ToString() : "")
                + (item.AppUser?.Surname?.Length > 0 ? item.AppUser.Surname[0].ToString() : "");

                <div class="comment-row">
                    <div class="comment-avatar-wrap">
                        @if (!string.IsNullOrEmpty(item.AppUser?.ImageURL))
                        {
                            <img src="@item.AppUser.ImageURL" class="comment-avatar" alt="@item.AppUser.Name" />
                        }
                        else
                        {
                            <div class="comment-avatar-fallback">@initials.ToUpper()</div>
                        }
                    </div>

                    <div class="comment-body">
                        <div class="comment-top">
                            <span class="comment-name">@item.AppUser?.Name @item.AppUser?.Surname</span>
                            <span class="comment-date">@item.CommentDate.ToString("dd MMM yyyy")</span>
                        </div>

                        @if (item.Article != null)
                        {
                            <div class="comment-article">
                                <i class="bi bi-file-text" style="font-size:0.6rem;"></i>
                                @item.Article.Title
                            </div>
                        }

                        <div class="comment-stars">
                            <i class="bx bxs-star"></i>
                            <i class="bx bxs-star"></i>
                            <i class="bx bxs-star"></i>
                            <i class="bx bxs-star"></i>
                            <i class="bx bxs-star"></i>
                        </div>

                        <p class="comment-text">@item.CommentDetail</p>
                    </div>
                </div>
            }
        </div>

        <div class="comments-footer">
            <span class="comments-footer-note">Toplam <span>@Model?.Count</span> yorum</span>
            <a href="#" class="comments-footer-link">Tümünü Görüntüle →</a>
        </div>

    </div>
</div>
