@model List<BlogListViewModel>
<div class="col-lg-8">
    @foreach (var item in Model)
    {
        <div class="bsingle__post mb-50">
            <div class="bsingle__post-thumb">
                <img src="@item.ImageUrl" style="width:900px;height:400px;" alt="">
            </div>
            <div class="bsingle__content">
                <div class="meta-info">
                    <ul>
                        <li><i class="fal fa-user"></i>@item.Author</li>
                        <li><i class="fal fa-calendar-alt"></i>@item.CreatedDate.ToString("dd-MMM-yyyy")</li>
                        <li><i class="fas fa-tags"></i>@item.CategoryName</li>
                        <li><i class="fas fa-comment"></i>@item.CommentCount</li>
                    </ul>
                </div>
                <h2>
                    <a href="/Blog/BlogDetail/@item.ArticleId">
                        @item.Title
                    </a>
                </h2>
                <p>@item.Summary</p>
                <div class="blog__btn">
                    <a href="/Blog/BlogDetail/@item.ArticleId" class="btn">Devamını Oku</a>
                </div>
            </div>
        </div>
    }
    <div class="pagination-wrap mb-50">
        <nav>
            <ul class="pagination">
                <li class="page-item"><a href="#"><i class="fas fa-angle-double-left"></i></a></li>
                <li class="page-item active"><a href="#">1</a></li>
                <li class="page-item"><a href="#">2</a></li>
                <li class="page-item"><a href="#">3</a></li>
                <li class="page-item"><a href="#">...</a></li>
                <li class="page-item"><a href="#">10</a></li>
                <li class="page-item"><a href="#"><i class="fas fa-angle-double-right"></i></a></li>
            </ul>
        </nav>
    </div>
</div>
