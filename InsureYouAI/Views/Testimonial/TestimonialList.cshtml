@model List<Testimonial>
@{
    ViewData["Title"] = "TestimonialList";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    int count = 0;
}

<style>
    .testimonial-card {
        background: linear-gradient(145deg, #1a1a2e 0%, #16213e 60%, #0f3460 100%);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 20px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.3), 0 0 0 1px rgba(255,255,255,0.02);
        overflow: hidden;
        position: relative;
    }

        .testimonial-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(20,184,166,0.45), transparent);
        }

    .testimonial-card-body {
        padding: 1.5rem 1.75rem;
    }

    /* Header */
    .testimonial-page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .testimonial-title-group {
        display: flex;
        align-items: center;
        gap: 0.7rem;
    }

    .testimonial-title-icon {
        width: 38px;
        height: 38px;
        border-radius: 11px;
        background: rgba(20,184,166,0.1);
        border: 1px solid rgba(20,184,166,0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #2dd4bf;
        font-size: 1rem;
    }

    .testimonial-title-group h5 {
        font-size: 0.95rem;
        font-weight: 700;
        color: #e8e8f0;
        margin: 0;
    }

    .testimonial-count-badge {
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.07em;
        text-transform: uppercase;
        background: rgba(20,184,166,0.1);
        color: #2dd4bf;
        border: 1px solid rgba(20,184,166,0.2);
        padding: 2px 9px;
        border-radius: 20px;
    }

    /* Search */
    .search-wrap {
        position: relative;
        display: flex;
        align-items: center;
    }

    .search-icon-inner {
        position: absolute;
        left: 12px;
        color: rgba(255,255,255,0.3);
        font-size: 0.8rem;
        pointer-events: none;
    }

    .search-input {
        background: rgba(255,255,255,0.04) !important;
        border: 1px solid rgba(255,255,255,0.09) !important;
        border-radius: 10px !important;
        color: #e8e8f0 !important;
        padding: 0.5rem 1rem 0.5rem 2.2rem !important;
        font-size: 0.8rem !important;
        width: 220px;
        transition: all 0.2s ease;
    }

        .search-input::placeholder {
            color: rgba(255,255,255,0.25) !important;
        }

        .search-input:focus {
            outline: none !important;
            border-color: rgba(20,184,166,0.35) !important;
            box-shadow: 0 0 0 3px rgba(20,184,166,0.06) !important;
            background: rgba(255,255,255,0.06) !important;
            width: 260px;
        }

    /* Table */
    .testimonial-table {
        width: 100%;
        border-collapse: collapse;
        font-family: 'Segoe UI', sans-serif;
    }

        .testimonial-table thead tr {
            border-bottom: 1px solid rgba(255,255,255,0.06);
        }

        .testimonial-table thead th {
            padding: 0.6rem 1rem;
            font-size: 0.67rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: rgba(255,255,255,0.3);
            white-space: nowrap;
        }

        .testimonial-table tbody tr {
            border-bottom: 1px solid rgba(255,255,255,0.04);
            transition: background 0.15s ease;
        }

            .testimonial-table tbody tr:last-child {
                border-bottom: none;
            }

            .testimonial-table tbody tr:hover {
                background: rgba(255,255,255,0.025);
            }

        .testimonial-table tbody td {
            padding: 0.9rem 1rem;
            font-size: 0.82rem;
            color: rgba(255,255,255,0.6);
            vertical-align: middle;
        }

    /* Row num */
    .row-num {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 26px;
        height: 24px;
        padding: 0 6px;
        background: rgba(255,255,255,0.05);
        border-radius: 6px;
        font-size: 0.7rem;
        font-weight: 700;
        color: rgba(255,255,255,0.35);
    }

    /* Person cell */
    .person-cell {
        display: flex;
        align-items: center;
        gap: 0.55rem;
    }

    .person-avatar {
        width: 30px;
        height: 30px;
        border-radius: 9px;
        flex-shrink: 0;
        background: linear-gradient(135deg, rgba(20,184,166,0.25), rgba(20,184,166,0.08));
        border: 1px solid rgba(20,184,166,0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.62rem;
        font-weight: 700;
        color: #2dd4bf;
    }

    .person-name {
        font-weight: 600;
        color: #d8d8e8;
        font-size: 0.82rem;
        white-space: nowrap;
    }

    /* Title badge */
    .title-badge {
        display: inline-flex;
        align-items: center;
        font-size: 0.7rem;
        font-weight: 600;
        background: rgba(20,184,166,0.07);
        border: 1px solid rgba(20,184,166,0.15);
        color: #2dd4bf;
        padding: 3px 9px;
        border-radius: 7px;
        white-space: nowrap;
    }

    /* Comment */
    .comment-text {
        font-size: 0.77rem;
        color: rgba(255,255,255,0.38);
        line-height: 1.55;
        max-width: 400px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* Quote icon */
    .quote-mark {
        font-size: 0.65rem;
        color: rgba(20,184,166,0.4);
        margin-right: 3px;
        font-family: Georgia, serif;
    }

    /* Actions */
    .action-group {
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    .action-btn {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
        text-decoration: none;
        border: 1px solid transparent;
        transition: all 0.2s ease;
    }

        .action-btn.edit {
            color: #fbbf24;
            background: rgba(251,191,36,0.08);
            border-color: rgba(251,191,36,0.15);
        }

            .action-btn.edit:hover {
                background: rgba(251,191,36,0.18);
                border-color: rgba(251,191,36,0.35);
                transform: translateY(-1px);
            }

        .action-btn.delete {
            color: #f87171;
            background: rgba(248,113,113,0.08);
            border-color: rgba(248,113,113,0.15);
        }

            .action-btn.delete:hover {
                background: rgba(248,113,113,0.18);
                border-color: rgba(248,113,113,0.35);
                transform: translateY(-1px);
            }

    /* Footer */
    .table-footer-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.75rem;
        padding-top: 1.25rem;
        margin-top: 0.25rem;
        border-top: 1px solid rgba(255,255,255,0.05);
    }

    .table-footer-info {
        font-size: 0.7rem;
        color: rgba(255,255,255,0.25);
    }

        .table-footer-info span {
            color: rgba(255,255,255,0.45);
            font-weight: 600;
        }

    .btn-add-testimonial {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 0.55rem 1.1rem;
        font-size: 0.78rem;
        font-weight: 600;
        color: #051210;
        background: linear-gradient(135deg, #2dd4bf, #14b8a6);
        border: none;
        border-radius: 10px;
        text-decoration: none;
        transition: all 0.2s ease;
        box-shadow: 0 3px 14px rgba(20,184,166,0.22);
    }

        .btn-add-testimonial:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(20,184,166,0.35);
            color: #051210;
        }

    /* Empty / no-result */
    .empty-state {
        padding: 3rem;
        text-align: center;
        color: rgba(255,255,255,0.2);
        font-size: 0.82rem;
    }

    .no-result-row {
        display: none;
    }

        .no-result-row td {
            text-align: center !important;
            padding: 2rem !important;
            color: rgba(255,255,255,0.25) !important;
            font-size: 0.8rem;
        }
</style>

<div class="testimonial-card">
    <div class="testimonial-card-body">

        <!-- Header -->
        <div class="testimonial-page-header">
            <div class="testimonial-title-group">
                <div class="testimonial-title-icon">
                    <i class="bi bi-chat-quote-fill"></i>
                </div>
                <h5>Referans Yorumları</h5>
                <span class="testimonial-count-badge">@Model?.Count yorum</span>
            </div>

            <div class="search-wrap">
                <i class="bi bi-search search-icon-inner"></i>
                <input class="form-control search-input"
                       id="testimonialSearch"
                       type="text"
                       placeholder="İsim, unvan veya yorum ara..." />
            </div>
        </div>

        <!-- Table -->
        <div class="table-responsive">
            @if (Model != null && Model.Any())
            {
                <table class="testimonial-table" id="testimonialTable">
                    <thead>
                        <tr>
                            <th style="width:46px;">#</th>
                            <th>Ad Soyad</th>
                            <th>Unvan</th>
                            <th>Yorum</th>
                            <th style="width:90px; text-align:right; padding-right:1.1rem;">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            count++;
                            var initials = item.NameSurname?.Length > 0
                            ? string.Join("", item.NameSurname.Split(' ').Take(2).Select(w => w[0].ToString()))
                            : "?";

                            <tr class="testimonial-row">
                                <td><span class="row-num">@count</span></td>
                                <td>
                                    <div class="person-cell">
                                        <div class="person-avatar">@initials.ToUpper()</div>
                                        <span class="person-name t-name-val">@item.NameSurname</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="title-badge t-title-val">@item.Title</span>
                                </td>
                                <td>
                                    <span class="comment-text t-comment-val" title="@item.CommentDetail">
                                        <span class="quote-mark">"</span>@item.CommentDetail
                                    </span>
                                </td>
                                <td style="text-align:right;">
                                    <div class="action-group justify-content-end">
                                        <a href="/Testimonial/UpdateTestimonial/@item.TestimonialId"
                                           class="action-btn edit"
                                           title="Düzenle"
                                           data-bs-toggle="tooltip" data-bs-placement="top">
                                            <i class="bi bi-pencil-fill"></i>
                                        </a>
                                        <a href="/Testimonial/DeleteTestimonial/@item.TestimonialId"
                                           class="action-btn delete"
                                           title="Sil"
                                           data-bs-toggle="tooltip" data-bs-placement="top"
                                           onclick="return confirm('Bu referans yorumunu silmek istediğinize emin misiniz?')">
                                            <i class="bi bi-trash-fill"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                        <tr class="no-result-row" id="noResultRow">
                            <td colspan="5">
                                <div style="font-size:1.5rem; margin-bottom:.4rem;">🔍</div>
                                Aradığınız referans bulunamadı.
                            </td>
                        </tr>
                    </tbody>
                </table>
            }
            else
            {
                <div class="empty-state">
                    <div style="font-size:2.2rem; margin-bottom:.6rem;">💬</div>
                    Henüz referans yorumu eklenmemiş.
                </div>
            }
        </div>

        <!-- Footer -->
        <div class="table-footer-row">
            <span class="table-footer-info">
                Toplam <span id="visibleCount">@Model?.Count</span> yorum gösteriliyor
            </span>
            <a href="/Testimonial/CreateTestimonial/" class="btn-add-testimonial">
                <i class="bi bi-plus-lg"></i>
                Yeni Referans Ekle
            </a>
        </div>

    </div>
</div>

<script>
    document.getElementById('testimonialSearch')?.addEventListener('input', function () {
        const q = this.value.toLowerCase().trim();
        const rows = document.querySelectorAll('.testimonial-row');
        const noResult = document.getElementById('noResultRow');
        let visible = 0;

        rows.forEach(row => {
            const name    = row.querySelector('.t-name-val')?.textContent.toLowerCase()    || '';
            const title   = row.querySelector('.t-title-val')?.textContent.toLowerCase()   || '';
            const comment = row.querySelector('.t-comment-val')?.textContent.toLowerCase() || '';
            const show    = !q || name.includes(q) || title.includes(q) || comment.includes(q);
            row.style.display = show ? '' : 'none';
            if (show) visible++;
        });

        noResult.style.display = visible === 0 && q.length > 0 ? '' : 'none';
        document.getElementById('visibleCount').textContent = visible;
    });

    document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(el => {
        new bootstrap.Tooltip(el);
    });
</script>
