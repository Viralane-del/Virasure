@model Testimonial
@{
    ViewData["Title"] = "UpdateTestimonial";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card">
    <div class="card-body">
        <div class="d-flex align-items-center">
            <h5 class="mb-0">Referans Güncelleme Sayfası</h5>
        </div>
        <form method="post">
            <input type="hidden" asp-for="TestimonialId" />
            <div class="form-group">
                <label>Ad Soyad</label>
                <input type="text" class="form-control" asp-for="NameSurname" />
            </div>
            <div class="form-group">
                <label>Unvan</label>
                <input type="text" class="form-control" asp-for="Title" />
            </div>
            <div class="form-group">
                <label>Yorum</label>
                <textarea class="form-control" asp-for="CommentDetail" rows="5"></textarea>
            </div>
            <div class="form-group">
                <label>Görsel URL</label>
                <input type="text" class="form-control" asp-for="ImageURL" />
            </div>
            <button type="submit" class="btn btn-outline-primary mt-3">Referansı Güncelle</button>
        </form>
    </div>
</div>

