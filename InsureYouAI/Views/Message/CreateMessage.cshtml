@model Message
@{
    ViewData["Title"] = "CreateMessage";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card">
    <div class="card-body">
        <div class="d-flex align-items-center">
            <h5 class="mb-0">Yeni Mesaj Girişi</h5>
        </div>
        <form method="post">
            <div class="form-group">
                <label>Ad Soyad</label>
                <input type="text" class="form-control" asp-for="NameSurname" />
            </div>
            <div class="form-group">
                <label>Email</label>
                <input type="email" class="form-control" asp-for="Email" />
            </div>
            <div class="form-group">
                <label>Konu</label>
                <input type="text" class="form-control" asp-for="Subject" />
            </div>
            <div class="form-group">
                <label>Detay</label>
                <textarea class="form-control" asp-for="Detail" rows="5"></textarea>
            </div>
            <button type="submit" class="btn btn-outline-primary mt-3">Kaydet</button>
        </form>
    </div>
</div>

