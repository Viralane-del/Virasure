@model Category
@{
    ViewData["Title"] = "UpdateCategory";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .update-cat-card {
        background: linear-gradient(145deg, #1a1a2e 0%, #16213e 60%, #0f3460 100%);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 20px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.3), 0 0 0 1px rgba(255,255,255,0.02);
        overflow: hidden;
        position: relative;
        max-width: 560px;
    }

        .update-cat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(34,197,94,0.4), transparent);
        }

    .update-cat-body {
        padding: 1.75rem 2rem;
    }

    /* Header */
    .update-cat-header {
        display: flex;
        align-items: center;
        gap: 0.7rem;
        margin-bottom: 1.75rem;
    }

    .update-cat-icon {
        width: 40px;
        height: 40px;
        border-radius: 12px;
        background: rgba(34,197,94,0.1);
        border: 1px solid rgba(34,197,94,0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #4ade80;
        font-size: 1.05rem;
    }

    .update-cat-header h5 {
        font-size: 0.95rem;
        font-weight: 700;
        color: #e8e8f0;
        margin: 0;
        letter-spacing: -0.01em;
    }

    .update-cat-header p {
        font-size: 0.7rem;
        color: rgba(255,255,255,0.3);
        margin: 0;
        text-transform: uppercase;
        letter-spacing: 0.07em;
    }

    .update-divider {
        margin: 0 0 1.5rem;
        border: none;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.07), transparent);
    }

    /* ID info strip */
    .id-info-strip {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        background: rgba(34,197,94,0.05);
        border: 1px solid rgba(34,197,94,0.12);
        border-radius: 10px;
        padding: 0.6rem 0.9rem;
        margin-bottom: 1.25rem;
        font-size: 0.73rem;
        color: rgba(255,255,255,0.35);
    }

        .id-info-strip i {
            color: #4ade80;
            font-size: 0.8rem;
        }

        .id-info-strip strong {
            color: rgba(255,255,255,0.55);
            font-weight: 700;
        }

    /* Form */
    .form-label-custom {
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.09em;
        color: rgba(255,255,255,0.4);
        margin-bottom: 0.5rem;
    }

        .form-label-custom .required-dot {
            width: 5px;
            height: 5px;
            background: #f87171;
            border-radius: 50%;
        }

    .input-wrap {
        position: relative;
    }

    .input-icon {
        position: absolute;
        left: 13px;
        top: 50%;
        transform: translateY(-50%);
        color: rgba(255,255,255,0.25);
        font-size: 0.85rem;
        pointer-events: none;
        transition: color 0.2s;
    }

    .input-wrap:focus-within .input-icon {
        color: #4ade80;
    }

    .form-input-custom {
        width: 100%;
        background: rgba(255,255,255,0.04) !important;
        border: 1px solid rgba(255,255,255,0.09) !important;
        border-radius: 12px !important;
        color: #e8e8f0 !important;
        padding: 0.7rem 1rem 0.7rem 2.4rem !important;
        font-size: 0.85rem !important;
        transition: all 0.2s ease;
    }

        .form-input-custom::placeholder {
            color: rgba(255,255,255,0.2) !important;
        }

        .form-input-custom:focus {
            outline: none !important;
            border-color: rgba(34,197,94,0.4) !important;
            box-shadow: 0 0 0 3px rgba(34,197,94,0.07) !important;
            background: rgba(255,255,255,0.06) !important;
        }

    .input-hint {
        font-size: 0.68rem;
        color: rgba(255,255,255,0.22);
        margin-top: 0.4rem;
        padding-left: 2px;
    }

    .field-validation-error {
        display: block;
        font-size: 0.68rem;
        color: #f87171;
        margin-top: 0.35rem;
        padding-left: 2px;
    }

    /* Buttons */
    .form-actions {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        margin-top: 1.75rem;
        padding-top: 1.25rem;
        border-top: 1px solid rgba(255,255,255,0.05);
    }

    .btn-update {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 0.65rem 1.4rem;
        font-size: 0.82rem;
        font-weight: 600;
        letter-spacing: 0.02em;
        color: #0f1a0f;
        background: linear-gradient(135deg, #4ade80, #22c55e);
        border: none;
        border-radius: 11px;
        cursor: pointer;
        transition: all 0.25s ease;
        box-shadow: 0 3px 14px rgba(34,197,94,0.22);
    }

        .btn-update:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 22px rgba(34,197,94,0.35);
        }

    .btn-cancel {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 0.65rem 1.2rem;
        font-size: 0.82rem;
        font-weight: 600;
        color: rgba(255,255,255,0.4);
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.09);
        border-radius: 11px;
        text-decoration: none;
        transition: all 0.2s ease;
    }

        .btn-cancel:hover {
            background: rgba(255,255,255,0.08);
            color: rgba(255,255,255,0.65);
        }
</style>

<div class="update-cat-card">
    <div class="update-cat-body">

        <div class="update-cat-header">
            <div class="update-cat-icon">
                <i class="bi bi-pencil-square"></i>
            </div>
            <div>
                <h5>Kategori Güncelle</h5>
                <p>Mevcut kategoriyi düzenleyin</p>
            </div>
        </div>

        <hr class="update-divider" />

        <form method="post">
            <input type="hidden" asp-for="CategoryId" />

            <!-- ID bilgi şeridi -->
            <div class="id-info-strip">
                <i class="bi bi-info-circle-fill"></i>
                Kategori ID: <strong>#@Model?.CategoryId</strong>
                &nbsp;·&nbsp; Bu alan düzenlenemez.
            </div>

            <div class="mb-1">
                <label class="form-label-custom">
                    Kategori Adı
                    <span class="required-dot"></span>
                </label>
                <div class="input-wrap">
                    <input type="text"
                           class="form-input-custom"
                           asp-for="CategoryName"
                           placeholder="Kategori adını güncelleyin..."
                           required
                           autocomplete="off" />
                    <i class="bi bi-tag input-icon"></i>
                </div>
                <span asp-validation-for="CategoryName" class="field-validation-error"></span>
                <p class="input-hint">Kategori adı benzersiz ve açıklayıcı olmalıdır.</p>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-update">
                    <i class="bi bi-check-lg"></i>
                    Güncelle
                </button>
                <a href="/Category/CategoryList" class="btn-cancel">
                    <i class="bi bi-x-lg"></i>
                    İptal
                </a>
            </div>
        </form>

    </div>
</div>
