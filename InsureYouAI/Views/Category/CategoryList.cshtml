@model List<Category>
@{
    ViewData["Title"] = "CategoryList";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .category-page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .category-title-group {
        display: flex;
        align-items: center;
        gap: 0.7rem;
    }

    .category-title-icon {
        width: 38px;
        height: 38px;
        border-radius: 11px;
        background: rgba(255,193,7,0.1);
        border: 1px solid rgba(255,193,7,0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fbbf24;
        font-size: 1rem;
    }

    .category-title-group h5 {
        font-size: 0.95rem;
        font-weight: 700;
        color: #e8e8f0;
        margin: 0;
        letter-spacing: -0.01em;
    }

    .category-count-badge {
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.07em;
        text-transform: uppercase;
        background: rgba(255,193,7,0.1);
        color: #fbbf24;
        border: 1px solid rgba(255,193,7,0.2);
        padding: 2px 9px;
        border-radius: 20px;
    }

    /* Search */
    .search-wrap {
        position: relative;
        display: flex;
        align-items: center;
    }

        .search-wrap .search-icon-inner {
            position: absolute;
            left: 12px;
            color: rgba(255,255,255,0.3);
            font-size: 0.8rem;
            pointer-events: none;
            z-index: 1;
        }

    .search-input {
        background: rgba(255,255,255,0.04) !important;
        border: 1px solid rgba(255,255,255,0.09) !important;
        border-radius: 10px !important;
        color: #e8e8f0 !important;
        padding: 0.5rem 1rem 0.5rem 2.2rem !important;
        font-size: 0.8rem !important;
        width: 220px;
        transition: all 0.2s ease;
    }

        .search-input::placeholder {
            color: rgba(255,255,255,0.25) !important;
        }

        .search-input:focus {
            outline: none !important;
            border-color: rgba(255,193,7,0.35) !important;
            box-shadow: 0 0 0 3px rgba(255,193,7,0.06) !important;
            background: rgba(255,255,255,0.06) !important;
            width: 260px;
        }

    /* Card */
    .category-card {
        background: linear-gradient(145deg, #1a1a2e 0%, #16213e 60%, #0f3460 100%);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 20px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.3), 0 0 0 1px rgba(255,255,255,0.02);
        overflow: hidden;
        position: relative;
    }

        .category-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(255,193,7,0.4), transparent);
        }

    .category-card-body {
        padding: 1.5rem 1.75rem;
    }

    /* Table */
    .category-table {
        width: 100%;
        border-collapse: collapse;
        font-family: 'Segoe UI', sans-serif;
    }

        .category-table thead tr {
            border-bottom: 1px solid rgba(255,255,255,0.06);
        }

        .category-table thead th {
            padding: 0.6rem 1rem;
            font-size: 0.67rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: rgba(255,255,255,0.3);
            white-space: nowrap;
        }

        .category-table tbody tr {
            border-bottom: 1px solid rgba(255,255,255,0.04);
            transition: background 0.15s ease;
        }

            .category-table tbody tr:last-child {
                border-bottom: none;
            }

            .category-table tbody tr:hover {
                background: rgba(255,255,255,0.025);
            }

        .category-table tbody td {
            padding: 0.9rem 1rem;
            font-size: 0.82rem;
            color: rgba(255,255,255,0.65);
            vertical-align: middle;
        }

    /* ID badge */
    .id-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 28px;
        height: 24px;
        padding: 0 7px;
        background: rgba(255,255,255,0.06);
        border-radius: 6px;
        font-size: 0.7rem;
        font-weight: 700;
        color: rgba(255,255,255,0.4);
        font-variant-numeric: tabular-nums;
    }

    /* Category name */
    .cat-name-cell {
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }

    .cat-name-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: #fbbf24;
        box-shadow: 0 0 6px rgba(251,191,36,0.5);
        flex-shrink: 0;
    }

    .cat-name-text {
        font-weight: 600;
        color: #d8d8e8;
        font-size: 0.83rem;
    }

    /* Action buttons */
    .action-group {
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    .action-btn {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.78rem;
        text-decoration: none;
        border: 1px solid transparent;
        transition: all 0.2s ease;
    }

        .action-btn.view {
            color: #60a5fa;
            background: rgba(59,130,246,0.08);
            border-color: rgba(59,130,246,0.15);
        }

            .action-btn.view:hover {
                background: rgba(59,130,246,0.18);
                border-color: rgba(59,130,246,0.35);
                transform: translateY(-1px);
            }

        .action-btn.edit {
            color: #4ade80;
            background: rgba(251,191,36,0.08);
            border-color: rgba(251,191,36,0.15);
        }

            .action-btn.edit:hover {
                background: rgba(251,191,36,0.18);
                border-color: rgba(251,191,36,0.35);
                transform: translateY(-1px);
            }

        .action-btn.delete {
            color: #f87171;
            background: rgba(248,113,113,0.08);
            border-color: rgba(248,113,113,0.15);
        }

            .action-btn.delete:hover {
                background: rgba(248,113,113,0.18);
                border-color: rgba(248,113,113,0.35);
                transform: translateY(-1px);
            }

    /* Table footer */
    .table-footer-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.75rem;
        padding-top: 1.25rem;
        margin-top: 0.25rem;
        border-top: 1px solid rgba(255,255,255,0.05);
    }

    .table-footer-info {
        font-size: 0.7rem;
        color: rgba(255,255,255,0.25);
    }

        .table-footer-info span {
            color: rgba(255,255,255,0.45);
            font-weight: 600;
        }

    .btn-add-category {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 0.55rem 1.1rem;
        font-size: 0.78rem;
        font-weight: 600;
        color: #1a1a2e;
        background: linear-gradient(135deg, #ffd54f, #ffc107);
        border: none;
        border-radius: 10px;
        text-decoration: none;
        transition: all 0.2s ease;
        box-shadow: 0 3px 14px rgba(255,193,7,0.2);
    }

        .btn-add-category:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(255,193,7,0.32);
            color: #1a1a2e;
        }

    /* Empty state */
    .empty-state {
        padding: 3rem;
        text-align: center;
        color: rgba(255,255,255,0.2);
        font-size: 0.82rem;
    }

    .empty-state-icon {
        font-size: 2.2rem;
        margin-bottom: 0.6rem;
    }

    /* Search no-result */
    .no-result-row {
        display: none;
    }

        .no-result-row td {
            text-align: center;
            padding: 2rem !important;
            color: rgba(255,255,255,0.25) !important;
            font-size: 0.8rem;
        }
</style>

<div class="category-card">
    <div class="category-card-body">

        <!-- Header -->
        <div class="category-page-header">
            <div class="category-title-group">
                <div class="category-title-icon">
                    <i class="bi bi-tags-fill"></i>
                </div>
                <h5>Sigorta Kategori Listesi</h5>
                <span class="category-count-badge">@Model?.Count kayıt</span>
            </div>

            <div class="search-wrap">
                <i class="bi bi-search search-icon-inner"></i>
                <input class="form-control search-input"
                       id="categorySearch"
                       type="text"
                       placeholder="Kategori ara..." />
            </div>
        </div>

        <!-- Table -->
        <div class="table-responsive">
            @if (Model != null && Model.Any())
            {
                <table class="category-table" id="categoryTable">
                    <thead>
                        <tr>
                            <th style="width:60px;">#</th>
                            <th>Kategori Adı</th>
                            <th style="width:120px; text-align:right; padding-right:1.1rem;">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr class="cat-row">
                                <td>
                                    <span class="id-badge">@item.CategoryId</span>
                                </td>
                                <td>
                                    <div class="cat-name-cell">
                                        <span class="cat-name-dot"></span>
                                        <span class="cat-name-text cat-name-val">@item.CategoryName</span>
                                    </div>
                                </td>
                                <td style="text-align:right;">
                                    <div class="action-group justify-content-end">
                                        <a href="javascript:;"
                                           class="action-btn view"
                                           title="Görüntüle"
                                           data-bs-toggle="tooltip"
                                           data-bs-placement="top">
                                            <i class="bi bi-eye-fill"></i>
                                        </a>
                                        <a href="/Category/UpdateCategory/@item.CategoryId"
                                           class="action-btn edit"
                                           title="Düzenle"
                                           data-bs-toggle="tooltip"
                                           data-bs-placement="top">
                                            <i class="bi bi-pencil-fill"></i>
                                        </a>
                                        <a href="/Category/DeleteCategory/@item.CategoryId"
                                           class="action-btn delete"
                                           title="Sil"
                                           data-bs-toggle="tooltip"
                                           data-bs-placement="top"
                                           onclick="return confirm('Bu kategoriyi silmek istediğinize emin misiniz?')">
                                            <i class="bi bi-trash-fill"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                        <tr class="no-result-row" id="noResultRow">
                            <td colspan="3">
                                <div style="font-size:1.5rem; margin-bottom:.4rem;">🔍</div>
                                Aradığınız kategori bulunamadı.
                            </td>
                        </tr>
                    </tbody>
                </table>
            }
            else
            {
                <div class="empty-state">
                    <div class="empty-state-icon">🏷️</div>
                    Henüz kategori eklenmemiş.
                </div>
            }
        </div>

        <!-- Footer -->
        <div class="table-footer-row">
            <span class="table-footer-info">
                Toplam <span id="visibleCount">@Model?.Count</span> kategori gösteriliyor
            </span>
            <a href="/Category/CreateCategory/" class="btn-add-category">
                <i class="bi bi-plus-lg"></i>
                Yeni Kategori Ekle
            </a>
        </div>

    </div>
</div>

<script>
    // Live search
    document.getElementById('categorySearch')?.addEventListener('input', function () {
        const q = this.value.toLowerCase().trim();
        const rows = document.querySelectorAll('.cat-row');
        const noResult = document.getElementById('noResultRow');
        let visible = 0;

        rows.forEach(row => {
            const name = row.querySelector('.cat-name-val')?.textContent.toLowerCase() || '';
            const show = name.includes(q);
            row.style.display = show ? '' : 'none';
            if (show) visible++;
        });

        noResult.style.display = visible === 0 ? '' : 'none';
        document.getElementById('visibleCount').textContent = visible;
    });

    // Bootstrap tooltips
    document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(el => {
        new bootstrap.Tooltip(el);
    });
</script>
