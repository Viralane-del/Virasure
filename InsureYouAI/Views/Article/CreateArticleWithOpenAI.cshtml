@{
    ViewData["Title"] = "CreateArticleWithOpenAI";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .ai-card {
        background: linear-gradient(145deg, #1a1a2e 0%, #16213e 60%, #0f3460 100%);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 20px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.3), 0 0 0 1px rgba(255,255,255,0.02);
        overflow: hidden;
        position: relative;
        max-width: 100%;
    }

        .ai-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(168,85,247,0.5), rgba(59,130,246,0.4), transparent);
        }

    .ai-card-body {
        padding: 1.75rem 2rem;
    }

    /* Header */
    .ai-header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 1.75rem;
    }

    .ai-header-icon {
        width: 46px;
        height: 46px;
        border-radius: 14px;
        background: linear-gradient(135deg, rgba(168,85,247,0.2), rgba(59,130,246,0.1));
        border: 1px solid rgba(168,85,247,0.25);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        box-shadow: 0 0 20px rgba(168,85,247,0.15);
        animation: glow-pulse 3s ease-in-out infinite;
    }

    @@keyframes glow-pulse {
        0%, 100% {
            box-shadow: 0 0 20px rgba(168,85,247,0.15);
        }

        50% {
            box-shadow: 0 0 30px rgba(168,85,247,0.3);
        }
    }

    .ai-header-text h5 {
        font-size: 0.95rem;
        font-weight: 700;
        color: #e8e8f0;
        margin: 0;
    }

    .ai-header-text p {
        font-size: 0.7rem;
        color: rgba(255,255,255,0.3);
        margin: 0;
        text-transform: uppercase;
        letter-spacing: 0.07em;
    }

    .ai-badge {
        margin-left: auto;
        font-size: 0.62rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        background: linear-gradient(135deg, rgba(168,85,247,0.15), rgba(59,130,246,0.1));
        color: #c084fc;
        border: 1px solid rgba(168,85,247,0.25);
        padding: 3px 10px;
        border-radius: 20px;
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .ai-badge-dot {
        width: 5px;
        height: 5px;
        background: #a855f7;
        border-radius: 50%;
        box-shadow: 0 0 5px rgba(168,85,247,0.8);
        animation: blink-dot 1.5s ease-in-out infinite;
    }

    @@keyframes blink-dot {
        0%, 100% {
            opacity: 1;
        }

        50% {
            opacity: 0.3;
        }
    }

    .form-divider {
        margin: 0 0 1.5rem;
        border: none;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.07), transparent);
    }

    /* Prompt tips */
    .prompt-tips {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
        margin-bottom: 0.75rem;
    }

    .tip-chip {
        font-size: 0.67rem;
        font-weight: 600;
        color: rgba(255,255,255,0.35);
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 6px;
        padding: 3px 9px;
        cursor: pointer;
        transition: all 0.2s;
        user-select: none;
    }

        .tip-chip:hover {
            background: rgba(168,85,247,0.1);
            border-color: rgba(168,85,247,0.25);
            color: #c084fc;
        }

    /* Field label */
    .field-label {
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.09em;
        color: rgba(255,255,255,0.38);
        margin-bottom: 0.5rem;
    }

    /* Input */
    .input-wrap {
        position: relative;
    }

    .input-icon {
        position: absolute;
        left: 13px;
        top: 50%;
        transform: translateY(-50%);
        color: rgba(255,255,255,0.22);
        font-size: 0.82rem;
        pointer-events: none;
        transition: color 0.2s;
    }

    .input-wrap:focus-within .input-icon {
        color: #a855f7;
    }

    .prompt-input {
        width: 100%;
        background: rgba(255,255,255,0.04) !important;
        border: 1px solid rgba(255,255,255,0.09) !important;
        border-radius: 12px !important;
        color: #e8e8f0 !important;
        padding: 0.75rem 1rem 0.75rem 2.4rem !important;
        font-size: 0.85rem !important;
        transition: all 0.2s ease;
    }

        .prompt-input::placeholder {
            color: rgba(255,255,255,0.18) !important;
        }

        .prompt-input:focus {
            outline: none !important;
            border-color: rgba(168,85,247,0.4) !important;
            box-shadow: 0 0 0 3px rgba(168,85,247,0.07) !important;
            background: rgba(255,255,255,0.06) !important;
        }

    .input-hint {
        font-size: 0.67rem;
        color: rgba(255,255,255,0.2);
        margin-top: 0.4rem;
        padding-left: 2px;
    }

    /* Submit button */
    .form-actions {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-top: 1.4rem;
    }

    .btn-ai {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 0.7rem 1.6rem;
        font-size: 0.83rem;
        font-weight: 600;
        color: #fff;
        background: linear-gradient(135deg, #a855f7, #7c3aed);
        border: none;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.25s ease;
        box-shadow: 0 3px 16px rgba(168,85,247,0.3);
        position: relative;
        overflow: hidden;
    }

        .btn-ai::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(255,255,255,0.1), transparent);
            opacity: 0;
            transition: opacity 0.2s;
        }

        .btn-ai:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 24px rgba(168,85,247,0.45);
        }

            .btn-ai:hover::before {
                opacity: 1;
            }

        .btn-ai:active {
            transform: translateY(0);
        }

    .btn-ai-icon {
        font-size: 0.9rem;
        animation: spin-slow 4s linear infinite;
    }

    @@keyframes spin-slow {
        from {
            transform: rotate(0deg);
        }

        to {
            transform: rotate(360deg);
        }
    }

    .char-counter {
        font-size: 0.68rem;
        color: rgba(255,255,255,0.2);
        margin-left: auto;
    }

        .char-counter.warn {
            color: #fbbf24;
        }

        .char-counter.limit {
            color: #f87171;
        }

    /* Result section */
    .result-section {
        margin-top: 1.75rem;
        padding-top: 1.5rem;
        border-top: 1px solid rgba(255,255,255,0.05);
    }

    .result-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1rem;
    }

    .result-title {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        font-size: 0.8rem;
        font-weight: 700;
        color: rgba(255,255,255,0.55);
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .result-title-dot {
        width: 7px;
        height: 7px;
        background: #4ade80;
        border-radius: 50%;
        box-shadow: 0 0 6px rgba(74,222,128,0.6);
    }

    .result-copy-btn {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 0.7rem;
        font-weight: 600;
        color: rgba(255,255,255,0.3);
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 8px;
        padding: 4px 10px;
        cursor: pointer;
        transition: all 0.2s;
        text-decoration: none;
    }

        .result-copy-btn:hover {
            background: rgba(255,255,255,0.08);
            color: rgba(255,255,255,0.6);
        }

    .result-box {
        background: rgba(0,0,0,0.25);
        border: 1px solid rgba(74,222,128,0.12);
        border-radius: 14px;
        padding: 1.4rem 1.6rem;
        position: relative;
        overflow: hidden;
    }

        .result-box::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(74,222,128,0.3), transparent);
        }

    .result-box-content {
        font-size: 0.85rem;
        color: rgba(255,255,255,0.7);
        line-height: 1.75;
    }

        .result-box-content h1,
        .result-box-content h2,
        .result-box-content h3 {
            color: #e8e8f0;
            margin-bottom: 0.5rem;
        }

        .result-box-content p {
            margin-bottom: 0.75rem;
        }

        .result-box-content strong {
            color: #c084fc;
        }

        .result-box-content ul,
        .result-box-content ol {
            padding-left: 1.2rem;
            margin-bottom: 0.75rem;
        }

        .result-box-content li {
            margin-bottom: 0.3rem;
        }

    /* Save to article strip */
    .save-strip {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-top: 1rem;
        padding: 0.85rem 1rem;
        background: rgba(34,197,94,0.05);
        border: 1px solid rgba(34,197,94,0.12);
        border-radius: 11px;
    }

    .save-strip-text {
        font-size: 0.73rem;
        color: rgba(255,255,255,0.35);
    }

        .save-strip-text i {
            color: #4ade80;
            margin-right: 4px;
        }

    .btn-save-article {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 0.5rem 1.1rem;
        font-size: 0.75rem;
        font-weight: 600;
        color: #0f1a0f;
        background: linear-gradient(135deg, #4ade80, #22c55e);
        border: none;
        border-radius: 9px;
        text-decoration: none;
        cursor: pointer;
        transition: all 0.2s;
        box-shadow: 0 2px 10px rgba(34,197,94,0.2);
    }

        .btn-save-article:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 16px rgba(34,197,94,0.32);
            color: #0f1a0f;
        }
</style>

<div class="ai-card">
    <div class="ai-card-body">

        <!-- Header -->
        <div class="ai-header">
            <div class="ai-header-icon">✨</div>
            <div class="ai-header-text">
                <h5>OpenAI ile Makale Oluştur</h5>
                <p>Yapay zeka destekli içerik üretimi</p>
            </div>
            <span class="ai-badge">
                <span class="ai-badge-dot"></span>
                GPT Aktif
            </span>
        </div>

        <hr class="form-divider" />

        <form method="post" id="aiForm">

            <div class="field-label">Prompt / Anahtar Kelimeler</div>

            <!-- Hazır prompt önerileri -->
            <div class="prompt-tips">
                <span class="tip-chip" onclick="setPrompt(this)">🚗 Kasko Sigortası Rehberi</span>
                <span class="tip-chip" onclick="setPrompt(this)">🏠 Konut Sigortası Avantajları</span>
                <span class="tip-chip" onclick="setPrompt(this)">🩺 Sağlık Sigortası Seçimi</span>
                <span class="tip-chip" onclick="setPrompt(this)">✈️ Seyahat Sigortası İpuçları</span>
                <span class="tip-chip" onclick="setPrompt(this)">🐾 Evcil Hayvan Sigortası</span>
            </div>

            <div class="input-wrap mb-1">
                <input type="text"
                       name="prompt"
                       id="promptInput"
                       class="prompt-input"
                       placeholder="Örn: Kasko sigortasının avantajları ve dikkat edilmesi gereken noktalar..."
                       maxlength="500"
                       autocomplete="off" />
                <i class="bi bi-stars input-icon"></i>
            </div>

            <p class="input-hint">Ne kadar detaylı prompt girerseniz, makale o kadar iyi çıkar.</p>

            <div class="form-actions">
                <button type="submit" class="btn-ai" id="submitBtn">
                    <span class="btn-ai-icon">⚙️</span>
                    AI ile Makale Oluştur
                </button>
                <span class="char-counter" id="charCounter">0 / 500</span>
            </div>
        </form>

        <!-- Sonuç -->
        @if (ViewBag.article != null)
        {
            <div class="result-section">
                <div class="result-header">
                    <div class="result-title">
                        <span class="result-title-dot"></span>
                        Oluşturulan Makale
                    </div>
                    <button class="result-copy-btn" onclick="copyResult()">
                        <i class="bi bi-clipboard"></i>
                        Kopyala
                    </button>
                </div>

                <div class="result-box" id="resultBox">
                    <div class="result-box-content">
                        @Html.Raw(ViewBag.article)
                    </div>
                </div>

                <div class="save-strip">
                    <span class="save-strip-text">
                        <i class="bi bi-check-circle-fill"></i>
                        Makale başarıyla oluşturuldu. Kaydetmek ister misiniz?
                    </span>
                    <a href="/Article/CreateArticle" class="btn-save-article">
                        <i class="bi bi-floppy-fill"></i>
                        Makale Olarak Kaydet
                    </a>
                </div>
            </div>
        }

    </div>
</div>

<script>
    // Karakter sayacı
    const promptInput   = document.getElementById('promptInput');
    const charCounter   = document.getElementById('charCounter');

    promptInput?.addEventListener('input', function () {
        const len = this.value.length;
        charCounter.textContent = len + ' / 500';
        charCounter.className = 'char-counter' + (len > 400 ? (len > 480 ? ' limit' : ' warn') : '');
    });

    // Hazır prompt chip'leri
    function setPrompt(el) {
        const text = el.textContent.replace(/^[\p{Emoji}\s]+/u, '').trim();
        if (promptInput) {
            promptInput.value = text;
            promptInput.dispatchEvent(new Event('input'));
            promptInput.focus();
        }
    }

    // Kopyala
    function copyResult() {
        const content = document.getElementById('resultBox')?.innerText || '';
        navigator.clipboard.writeText(content).then(() => {
            const btn = document.querySelector('.result-copy-btn');
            if (btn) {
                btn.innerHTML = '<i class="bi bi-check-lg"></i> Kopyalandı';
                setTimeout(() => {
                    btn.innerHTML = '<i class="bi bi-clipboard"></i> Kopyala';
                }, 2000);
            }
        });
    }

    // Submit: buton loading state
    document.getElementById('aiForm')?.addEventListener('submit', function () {
        const btn = document.getElementById('submitBtn');
        if (btn) {
            btn.innerHTML = '<span style="animation:spin-slow 1s linear infinite; display:inline-block;">⚙️</span> Oluşturuluyor...';
            btn.disabled = true;
            btn.style.opacity = '0.75';
        }
    });
</script>
