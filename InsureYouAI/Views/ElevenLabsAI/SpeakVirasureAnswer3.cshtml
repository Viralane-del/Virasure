@{
    ViewData["Title"] = "AI Yanıtını Seslendir";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .voice-card {
        background: linear-gradient(145deg, #1a1a2e 0%, #16213e 60%, #0f3460 100%);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 20px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.3);
        overflow: hidden;
        position: relative;
        max-width: 100%;
        display: flex;
        flex-direction: column;
        height: calc(100vh - 120px);
        min-height: 520px;
    }

        .voice-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(251,191,36,0.4), rgba(168,85,247,0.3), transparent);
        }

    /* ── Header ── */
    .voice-header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1.1rem 1.5rem;
        border-bottom: 1px solid rgba(255,255,255,0.05);
        background: rgba(0,0,0,0.15);
        flex-shrink: 0;
    }

    .voice-header-icon {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        background: linear-gradient(135deg, rgba(251,191,36,0.2), rgba(168,85,247,0.1));
        border: 1px solid rgba(251,191,36,0.25);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.15rem;
        animation: icon-glow 3s ease-in-out infinite;
    }

    @@keyframes icon-glow {
        0%, 100% {
            box-shadow: 0 0 16px rgba(251,191,36,0.1);
        }

        50% {
            box-shadow: 0 0 26px rgba(251,191,36,0.25);
        }
    }

    .voice-header-info h5 {
        font-size: 0.9rem;
        font-weight: 700;
        color: #e8e8f0;
        margin: 0;
    }

    .voice-header-info p {
        font-size: 0.68rem;
        color: rgba(255,255,255,0.3);
        margin: 0;
    }

    .elevenlabs-badge {
        margin-left: auto;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 0.62rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        background: rgba(251,191,36,0.1);
        color: #fbbf24;
        border: 1px solid rgba(251,191,36,0.2);
        padding: 3px 10px;
        border-radius: 20px;
    }

    .elev-dot {
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: #fbbf24;
        box-shadow: 0 0 6px rgba(251,191,36,0.8);
        animation: blink 1.5s ease-in-out infinite;
    }

    @@keyframes blink {
        0%, 100% {
            opacity: 1;
        }

        50% {
            opacity: 0.3;
        }
    }

    /* ── Avatar speaking area ── */
    .avatar-zone {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 1rem 1.5rem 0.5rem;
        flex-shrink: 0;
    }

    .ai-avatar-wrap {
        position: relative;
        width: 72px;
        height: 72px;
    }

    .ai-avatar-circle {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background: linear-gradient(135deg, rgba(168,85,247,0.25), rgba(251,191,36,0.1));
        border: 2px solid rgba(168,85,247,0.3);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        position: relative;
        z-index: 1;
    }

    /* Speaking rings */
    .speaking-ring {
        position: absolute;
        border-radius: 50%;
        border: 2px solid rgba(251,191,36,0.3);
        animation: ring-pulse 1.8s ease-out infinite;
        display: none;
    }

        .speaking-ring:nth-child(1) {
            inset: -8px;
            animation-delay: 0s;
        }

        .speaking-ring:nth-child(2) {
            inset: -16px;
            animation-delay: 0.4s;
        }

        .speaking-ring:nth-child(3) {
            inset: -24px;
            animation-delay: 0.8s;
        }

    @@keyframes ring-pulse {
        0% {
            opacity: 0.6;
            transform: scale(1);
        }

        100% {
            opacity: 0;
            transform: scale(1.15);
        }
    }

    .ai-avatar-wrap.speaking .speaking-ring {
        display: block;
    }

    .ai-avatar-wrap.speaking .ai-avatar-circle {
        border-color: rgba(251,191,36,0.5);
        box-shadow: 0 0 20px rgba(251,191,36,0.2);
    }

    /* Sound bars */
    .sound-bars {
        display: none;
        align-items: flex-end;
        gap: 3px;
        height: 20px;
        margin-top: 0.5rem;
    }

    .sound-bar {
        width: 3px;
        border-radius: 2px;
        background: #fbbf24;
        animation: bar-wave 0.8s ease-in-out infinite;
    }

        .sound-bar:nth-child(1) {
            height: 8px;
            animation-delay: 0s;
        }

        .sound-bar:nth-child(2) {
            height: 14px;
            animation-delay: 0.1s;
        }

        .sound-bar:nth-child(3) {
            height: 20px;
            animation-delay: 0.2s;
        }

        .sound-bar:nth-child(4) {
            height: 14px;
            animation-delay: 0.3s;
        }

        .sound-bar:nth-child(5) {
            height: 8px;
            animation-delay: 0.4s;
        }

    @@keyframes bar-wave {
        0%, 100% {
            transform: scaleY(0.4);
        }

        50% {
            transform: scaleY(1);
        }
    }

    .avatar-zone.speaking .sound-bars {
        display: flex;
    }

    .avatar-status {
        font-size: 0.68rem;
        color: rgba(255,255,255,0.3);
        margin-top: 0.4rem;
        text-align: center;
    }

        .avatar-status.active {
            color: #fbbf24;
        }

    /* ── Messages ── */
    .chat-messages {
        flex: 1;
        overflow-y: auto;
        padding: 0.75rem 1.5rem 0.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.65rem;
        scroll-behavior: smooth;
    }

        .chat-messages::-webkit-scrollbar {
            width: 4px;
        }

        .chat-messages::-webkit-scrollbar-track {
            background: transparent;
        }

        .chat-messages::-webkit-scrollbar-thumb {
            background: rgba(255,255,255,0.1);
            border-radius: 4px;
        }

    .msg-row {
        display: flex;
        align-items: flex-end;
        gap: 0.5rem;
        animation: fade-in 0.2s ease;
    }

    @@keyframes fade-in {
        from {
            opacity: 0;
            transform: translateY(5px);
        }

        to {
            opacity: 1;
            transform: none;
        }
    }

    .msg-row.user {
        flex-direction: row-reverse;
    }

    .msg-row.ai {
        flex-direction: row;
    }

    .msg-avatar {
        width: 26px;
        height: 26px;
        border-radius: 7px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.65rem;
        font-weight: 700;
        flex-shrink: 0;
    }

        .msg-avatar.user-av {
            background: rgba(59,130,246,0.15);
            border: 1px solid rgba(59,130,246,0.25);
            color: #60a5fa;
        }

        .msg-avatar.ai-av {
            background: rgba(251,191,36,0.12);
            border: 1px solid rgba(251,191,36,0.25);
            color: #fbbf24;
        }

    .msg-bubble {
        max-width: 74%;
        padding: 0.65rem 0.95rem;
        border-radius: 13px;
        font-size: 0.82rem;
        line-height: 1.65;
        word-break: break-word;
    }

        .msg-bubble.user {
            background: rgba(59,130,246,0.12);
            border: 1px solid rgba(59,130,246,0.2);
            color: #cce0ff;
            border-bottom-right-radius: 4px;
        }

        .msg-bubble.ai {
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.07);
            color: rgba(255,255,255,0.72);
            border-bottom-left-radius: 4px;
        }

            .msg-bubble.ai .audio-play-btn {
                display: inline-flex;
                align-items: center;
                gap: 5px;
                margin-top: 0.5rem;
                font-size: 0.68rem;
                font-weight: 600;
                color: #fbbf24;
                background: rgba(251,191,36,0.08);
                border: 1px solid rgba(251,191,36,0.2);
                border-radius: 7px;
                padding: 3px 9px;
                cursor: pointer;
                transition: all 0.15s;
                text-decoration: none;
            }

                .msg-bubble.ai .audio-play-btn:hover {
                    background: rgba(251,191,36,0.15);
                    border-color: rgba(251,191,36,0.35);
                }

    /* Typing */
    .typing-row {
        display: none;
        flex-direction: row;
        align-items: flex-end;
        gap: 0.5rem;
    }

    .typing-bubble {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.07);
        border-radius: 13px;
        border-bottom-left-radius: 4px;
        padding: 0.55rem 0.85rem;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .typing-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: rgba(251,191,36,0.5);
        animation: t-bounce 1.2s ease-in-out infinite;
    }

        .typing-dot:nth-child(2) {
            animation-delay: 0.2s;
        }

        .typing-dot:nth-child(3) {
            animation-delay: 0.4s;
        }

    @@keyframes t-bounce {
        0%, 60%, 100% {
            transform: translateY(0);
            opacity: 0.4;
        }

        30% {
            transform: translateY(-5px);
            opacity: 1;
        }
    }

    /* ── Input ── */
    .voice-input-area {
        padding: 0.85rem 1.5rem 1rem;
        border-top: 1px solid rgba(255,255,255,0.05);
        background: rgba(0,0,0,0.1);
        flex-shrink: 0;
    }

    .voice-textarea {
        width: 100%;
        background: rgba(255,255,255,0.04) !important;
        border: 1px solid rgba(255,255,255,0.09) !important;
        border-radius: 12px !important;
        color: #e8e8f0 !important;
        padding: 0.7rem 1rem !important;
        font-size: 0.84rem !important;
        resize: none;
        transition: all 0.2s;
        line-height: 1.5;
    }

        .voice-textarea::placeholder {
            color: rgba(255,255,255,0.2) !important;
        }

        .voice-textarea:focus {
            outline: none !important;
            border-color: rgba(251,191,36,0.35) !important;
            box-shadow: 0 0 0 3px rgba(251,191,36,0.06) !important;
            background: rgba(255,255,255,0.06) !important;
        }

    .input-actions {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: 0.55rem;
    }

    .input-hint-text {
        font-size: 0.63rem;
        color: rgba(255,255,255,0.18);
    }

    .btn-voice-send {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 0.6rem 1.3rem;
        font-size: 0.8rem;
        font-weight: 600;
        color: #1a1208;
        background: linear-gradient(135deg, #ffd54f, #ffc107);
        border: none;
        border-radius: 10px;
        cursor: pointer;
        transition: all 0.2s;
        box-shadow: 0 3px 12px rgba(255,193,7,0.22);
    }

        .btn-voice-send:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 18px rgba(255,193,7,0.35);
        }

        .btn-voice-send:disabled {
            opacity: 0.5;
            transform: none;
            cursor: not-allowed;
        }
</style>

<div class="voice-card">

    <!-- Header -->
    <div class="voice-header">
        <div class="voice-header-icon">🎙️</div>
        <div class="voice-header-info">
            <h5>AI Yanıtını Seslendir</h5>
            <p>ElevenLabs · Gerçek zamanlı ses sentezi</p>
        </div>
        <span class="elevenlabs-badge">
            <span class="elev-dot"></span>
            ElevenLabs
        </span>
    </div>

    <!-- Avatar -->
    <div class="avatar-zone" id="avatarZone">
        <div class="ai-avatar-wrap" id="avatarWrap">
            <span class="speaking-ring"></span>
            <span class="speaking-ring"></span>
            <span class="speaking-ring"></span>
            <div class="ai-avatar-circle">🤖</div>
        </div>
        <div class="sound-bars">
            <div class="sound-bar"></div>
            <div class="sound-bar"></div>
            <div class="sound-bar"></div>
            <div class="sound-bar"></div>
            <div class="sound-bar"></div>
        </div>
        <p class="avatar-status" id="avatarStatus">Yanıt bekleniyor</p>
    </div>

    <!-- Messages -->
    <div class="chat-messages" id="chatArea">
        <div class="msg-row ai">
            <div class="msg-avatar ai-av">AI</div>
            <div class="msg-bubble ai">Merhaba! Ben Virasure AI. Sorunuzu yazın, sesli yanıtlayayım. 🎧</div>
        </div>
    </div>

    <!-- Typing indicator -->
    <div style="padding: 0 1.5rem 0.4rem;">
        <div class="typing-row" id="typingRow">
            <div class="msg-avatar ai-av">AI</div>
            <div class="typing-bubble">
                <span class="typing-dot"></span>
                <span class="typing-dot"></span>
                <span class="typing-dot"></span>
            </div>
        </div>
    </div>

    <!-- Input -->
    <div class="voice-input-area">
        <form method="post" id="askForm">
            <textarea name="text" id="text" class="form-control voice-textarea"
                      rows="2" placeholder="Sorunuzu yazın..."></textarea>
            <div class="input-actions">
                <span class="input-hint-text">
                    <i class="bi bi-volume-up" style="margin-right:3px;color:rgba(255,193,7,0.4);"></i>
                    Yanıt otomatik seslendirilecek
                </span>
                <button type="submit" class="btn-voice-send" id="sendBtn">
                    <i class="bi bi-send-fill"></i>
                    Gönder & Seslendir
                </button>
            </div>
        </form>
    </div>

</div>

<audio id="voiceAudio"></audio>

<script>
    const chatArea   = document.getElementById("chatArea");
    const audio      = document.getElementById("voiceAudio");
    const avatarWrap = document.getElementById("avatarWrap");
    const avatarZone = document.getElementById("avatarZone");
    const avatarStatus = document.getElementById("avatarStatus");
    const typingRow  = document.getElementById("typingRow");
    const sendBtn    = document.getElementById("sendBtn");

    function addMsg(type, html, audioUrl) {
        const row = document.createElement('div');
        row.className = `msg-row ${type}`;

        const av = document.createElement('div');
        av.className = `msg-avatar ${type === 'user' ? 'user-av' : 'ai-av'}`;
        av.textContent = type === 'user' ? 'Sen' : 'AI';

        const bubble = document.createElement('div');
        bubble.className = `msg-bubble ${type}`;
        bubble.innerHTML = html;

        if (type === 'ai' && audioUrl) {
            const playBtn = document.createElement('a');
            playBtn.className = 'audio-play-btn';
            playBtn.innerHTML = '<i class="bi bi-play-circle-fill"></i> Tekrar Oynat';
            playBtn.href = 'javascript:;';
            playBtn.onclick = () => { audio.src = audioUrl; audio.play(); };
            bubble.appendChild(document.createElement('br'));
            bubble.appendChild(playBtn);
        }

        if (type === 'user') { row.appendChild(bubble); row.appendChild(av); }
        else                 { row.appendChild(av);     row.appendChild(bubble); }

        chatArea.appendChild(row);
        chatArea.scrollTop = chatArea.scrollHeight;
    }

    function setSpeaking(active) {
        if (active) {
            avatarWrap.classList.add('speaking');
            avatarZone.classList.add('speaking');
            avatarStatus.textContent = 'Konuşuyor...';
            avatarStatus.className = 'avatar-status active';
        } else {
            avatarWrap.classList.remove('speaking');
            avatarZone.classList.remove('speaking');
            avatarStatus.textContent = 'Yanıt bekleniyor';
            avatarStatus.className = 'avatar-status';
        }
    }

    document.getElementById("askForm").addEventListener("submit", function () {
        const text = document.getElementById("text").value.trim();
        if (!text) return;

        addMsg('user', text);
        document.getElementById("text").value = "";
        sendBtn.disabled = true;
        typingRow.style.display = 'flex';
        avatarStatus.textContent = 'Düşünüyor...';
        chatArea.scrollTop = chatArea.scrollHeight;
    });

    @if (ViewBag.AudioUrl != null && ViewBag.Answer != null)
    {
            <text>
            // Typing kaldır
            typingRow.style.display = 'none';
            sendBtn.disabled = false;

            // AI yanıtını ekle
            addMsg('ai', `@Html.Raw(ViewBag.Answer)`, '@ViewBag.AudioUrl');

            // Ses oynat
            audio.src = "@ViewBag.AudioUrl";
            audio.pause();
            audio.currentTime = 0;

            setSpeaking(true);
            audio.play().catch(() => {});

            audio.onended = function () {
                setSpeaking(false);
            };
            </text>
    }
</script>
