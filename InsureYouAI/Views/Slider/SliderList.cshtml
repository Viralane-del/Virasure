@model List<Slider>
@{
    ViewData["Title"] = "SliderList";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    int count = 0;
}

<style>
    .slider-card {
        background: linear-gradient(145deg, #1a1a2e 0%, #16213e 60%, #0f3460 100%);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 20px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.3), 0 0 0 1px rgba(255,255,255,0.02);
        overflow: hidden;
        position: relative;
    }

        .slider-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(251,191,36,0.45), transparent);
        }

    .slider-card-body {
        padding: 1.5rem 1.75rem;
    }

    /* Header */
    .slider-page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .slider-title-group {
        display: flex;
        align-items: center;
        gap: 0.7rem;
    }

    .slider-title-icon {
        width: 38px;
        height: 38px;
        border-radius: 11px;
        background: rgba(251,191,36,0.1);
        border: 1px solid rgba(251,191,36,0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fbbf24;
        font-size: 1rem;
    }

    .slider-title-group h5 {
        font-size: 0.95rem;
        font-weight: 700;
        color: #e8e8f0;
        margin: 0;
    }

    .slider-count-badge {
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.07em;
        text-transform: uppercase;
        background: rgba(251,191,36,0.1);
        color: #fbbf24;
        border: 1px solid rgba(251,191,36,0.2);
        padding: 2px 9px;
        border-radius: 20px;
    }

    /* Search */
    .search-wrap {
        position: relative;
        display: flex;
        align-items: center;
    }

    .search-icon-inner {
        position: absolute;
        left: 12px;
        color: rgba(255,255,255,0.3);
        font-size: 0.8rem;
        pointer-events: none;
    }

    .search-input {
        background: rgba(255,255,255,0.04) !important;
        border: 1px solid rgba(255,255,255,0.09) !important;
        border-radius: 10px !important;
        color: #e8e8f0 !important;
        padding: 0.5rem 1rem 0.5rem 2.2rem !important;
        font-size: 0.8rem !important;
        width: 220px;
        transition: all 0.2s ease;
    }

        .search-input::placeholder {
            color: rgba(255,255,255,0.25) !important;
        }

        .search-input:focus {
            outline: none !important;
            border-color: rgba(251,191,36,0.35) !important;
            box-shadow: 0 0 0 3px rgba(251,191,36,0.06) !important;
            background: rgba(255,255,255,0.06) !important;
            width: 260px;
        }

    /* Table */
    .slider-table {
        width: 100%;
        border-collapse: collapse;
        font-family: 'Segoe UI', sans-serif;
    }

        .slider-table thead tr {
            border-bottom: 1px solid rgba(255,255,255,0.06);
        }

        .slider-table thead th {
            padding: 0.6rem 1rem;
            font-size: 0.67rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: rgba(255,255,255,0.3);
            white-space: nowrap;
        }

        .slider-table tbody tr {
            border-bottom: 1px solid rgba(255,255,255,0.04);
            transition: background 0.15s ease;
        }

            .slider-table tbody tr:last-child {
                border-bottom: none;
            }

            .slider-table tbody tr:hover {
                background: rgba(255,255,255,0.025);
            }

        .slider-table tbody td {
            padding: 0.9rem 1rem;
            font-size: 0.82rem;
            color: rgba(255,255,255,0.6);
            vertical-align: middle;
        }

    /* Row num */
    .row-num {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 26px;
        height: 24px;
        padding: 0 6px;
        background: rgba(255,255,255,0.05);
        border-radius: 6px;
        font-size: 0.7rem;
        font-weight: 700;
        color: rgba(255,255,255,0.35);
    }

    /* Title */
    .title-cell {
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }

    .title-icon-mini {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        background: rgba(251,191,36,0.08);
        border: 1px solid rgba(251,191,36,0.15);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fbbf24;
        font-size: 0.7rem;
        flex-shrink: 0;
    }

    .title-text {
        font-weight: 600;
        color: #d8d8e8;
        font-size: 0.83rem;
    }

    /* Description */
    .desc-text {
        font-size: 0.78rem;
        color: rgba(255,255,255,0.38);
        line-height: 1.55;
        max-width: 500px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* Actions */
    .action-group {
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    .action-btn {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
        text-decoration: none;
        border: 1px solid transparent;
        transition: all 0.2s ease;
    }

        .action-btn.edit {
            color: #fbbf24;
            background: rgba(251,191,36,0.08);
            border-color: rgba(251,191,36,0.15);
        }

            .action-btn.edit:hover {
                background: rgba(251,191,36,0.18);
                border-color: rgba(251,191,36,0.35);
                transform: translateY(-1px);
            }

        .action-btn.delete {
            color: #f87171;
            background: rgba(248,113,113,0.08);
            border-color: rgba(248,113,113,0.15);
        }

            .action-btn.delete:hover {
                background: rgba(248,113,113,0.18);
                border-color: rgba(248,113,113,0.35);
                transform: translateY(-1px);
            }

    /* Footer */
    .table-footer-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.75rem;
        padding-top: 1.25rem;
        margin-top: 0.25rem;
        border-top: 1px solid rgba(255,255,255,0.05);
    }

    .table-footer-info {
        font-size: 0.7rem;
        color: rgba(255,255,255,0.25);
    }

        .table-footer-info span {
            color: rgba(255,255,255,0.45);
            font-weight: 600;
        }

    .btn-add-slider {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 0.55rem 1.1rem;
        font-size: 0.78rem;
        font-weight: 600;
        color: #1a1208;
        background: linear-gradient(135deg, #ffd54f, #ffc107);
        border: none;
        border-radius: 10px;
        text-decoration: none;
        transition: all 0.2s ease;
        box-shadow: 0 3px 14px rgba(255,193,7,0.22);
    }

        .btn-add-slider:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(255,193,7,0.35);
            color: #1a1208;
        }

    /* Empty / No-result */
    .empty-state {
        padding: 3rem;
        text-align: center;
        color: rgba(255,255,255,0.2);
        font-size: 0.82rem;
    }

    .no-result-row {
        display: none;
    }

        .no-result-row td {
            text-align: center !important;
            padding: 2rem !important;
            color: rgba(255,255,255,0.25) !important;
            font-size: 0.8rem;
        }
</style>

<div class="slider-card">
    <div class="slider-card-body">

        <!-- Header -->
        <div class="slider-page-header">
            <div class="slider-title-group">
                <div class="slider-title-icon">
                    <i class="bi bi-images"></i>
                </div>
                <h5>Slider Alanı Listesi</h5>
                <span class="slider-count-badge">@Model?.Count kayıt</span>
            </div>

            <div class="search-wrap">
                <i class="bi bi-search search-icon-inner"></i>
                <input class="form-control search-input"
                       id="sliderSearch"
                       type="text"
                       placeholder="Başlık veya açıklama ara..." />
            </div>
        </div>

        <!-- Table -->
        <div class="table-responsive">
            @if (Model != null && Model.Any())
            {
                <table class="slider-table" id="sliderTable">
                    <thead>
                        <tr>
                            <th style="width:46px;">#</th>
                            <th>Başlık</th>
                            <th>Açıklama</th>
                            <th style="width:90px; text-align:right; padding-right:1.1rem;">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            count++;
                            <tr class="slider-row">
                                <td><span class="row-num">@count</span></td>
                                <td>
                                    <div class="title-cell">
                                        <div class="title-icon-mini">
                                            <i class="bi bi-image"></i>
                                        </div>
                                        <span class="title-text slider-title-val">@item.Title</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="desc-text slider-desc-val" title="@item.Description">
                                        @item.Description
                                    </span>
                                </td>
                                <td style="text-align:right;">
                                    <div class="action-group justify-content-end">
                                        <a href="/Slider/UpdateSlider/@item.SliderId"
                                           class="action-btn edit"
                                           title="Düzenle"
                                           data-bs-toggle="tooltip" data-bs-placement="top">
                                            <i class="bi bi-pencil-fill"></i>
                                        </a>
                                        <a href="/Slider/DeleteSlider/@item.SliderId"
                                           class="action-btn delete"
                                           title="Sil"
                                           data-bs-toggle="tooltip" data-bs-placement="top"
                                           onclick="return confirm('Bu slider kaydını silmek istediğinize emin misiniz?')">
                                            <i class="bi bi-trash-fill"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                        <tr class="no-result-row" id="noResultRow">
                            <td colspan="4">
                                <div style="font-size:1.5rem; margin-bottom:.4rem;">🔍</div>
                                Aradığınız slider bulunamadı.
                            </td>
                        </tr>
                    </tbody>
                </table>
            }
            else
            {
                <div class="empty-state">
                    <div style="font-size:2.2rem; margin-bottom:.6rem;">🖼️</div>
                    Henüz slider kaydı eklenmemiş.
                </div>
            }
        </div>

        <!-- Footer -->
        <div class="table-footer-row">
            <span class="table-footer-info">
                Toplam <span id="visibleCount">@Model?.Count</span> kayıt gösteriliyor
            </span>
            <a href="/Slider/CreateSlider/" class="btn-add-slider">
                <i class="bi bi-plus-lg"></i>
                Yeni Slider Ekle
            </a>
        </div>

    </div>
</div>

<script>
    document.getElementById('sliderSearch')?.addEventListener('input', function () {
        const q = this.value.toLowerCase().trim();
        const rows = document.querySelectorAll('.slider-row');
        const noResult = document.getElementById('noResultRow');
        let visible = 0;

        rows.forEach(row => {
            const title = row.querySelector('.slider-title-val')?.textContent.toLowerCase() || '';
            const desc  = row.querySelector('.slider-desc-val')?.textContent.toLowerCase() || '';
            const show  = !q || title.includes(q) || desc.includes(q);
            row.style.display = show ? '' : 'none';
            if (show) visible++;
        });

        noResult.style.display = visible === 0 && q.length > 0 ? '' : 'none';
        document.getElementById('visibleCount').textContent = visible;
    });

    document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(el => {
        new bootstrap.Tooltip(el);
    });
</script>
