@{
    ViewData["Title"] = "Canlı Destek";
    Layout = "~/Views/Shared/_UILayout.cshtml";
}

<style>
    .support-wrapper {
        max-width: 900px;
        margin: 40px auto;
        background: #ffffff;
        border-radius: 16px;
        box-shadow: 0 10px 30px rgba(0,0,0,.08);
        overflow: hidden;
    }

    .support-header {
        background: linear-gradient(135deg, #4f7cff, #6a8dff);
        color: #fff;
        padding: 20px;
        font-size: 20px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .support-header span {
            font-size: 14px;
            opacity: .9;
            font-weight: 400;
        }

    .chat-body {
        padding: 20px;
        height: 360px;
        overflow-y: auto;
        background: #f8f9fc;
    }

    .msg {
        max-width: 75%;
        padding: 12px 14px;
        margin-bottom: 12px;
        border-radius: 12px;
        font-size: 14px;
        line-height: 1.5;
        white-space: pre-wrap;
    }

        .msg.user {
            margin-left: auto;
            background: #2c2f3a;
            color: #fff;
            border-bottom-right-radius: 4px;
        }

        .msg.ai {
            background: #ffffff;
            border: 1px solid #e4e6ef;
            border-bottom-left-radius: 4px;
        }

    .typing {
        font-size: 13px;
        font-style: italic;
        color: #6c757d;
        margin-top: 5px;
        display: none;
    }

    .chat-footer {
        display: flex;
        gap: 10px;
        padding: 16px;
        border-top: 1px solid #e4e6ef;
        background: #fff;
    }

        .chat-footer input {
            flex: 1;
            border-radius: 10px;
            border: 1px solid #d1d5db;
            padding: 10px 14px;
            font-size: 14px;
        }

        .chat-footer button {
            background: #4f7cff;
            color: #fff;
            border: none;
            border-radius: 10px;
            padding: 0 20px;
            font-weight: 600;
            cursor: pointer;
            transition: .2s;
        }

            .chat-footer button:hover {
                background: #3e66e0;
            }
</style>

<div class="support-wrapper">
    <div class="support-header">
        🤖 Virasure AI Destek
        <span>7/24 Sigorta Asistanı</span>
    </div>

    <div id="chat" class="chat-body"></div>
    <div id="typing" class="typing">Virasure AI yazıyor...</div>

    <div class="chat-footer">
        <input id="messageInput" type="text" placeholder="Sorunuzu yazın (ör. Sağlık sigortası nedir?)" />
        <button id="sendBtn">Gönder</button>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.0/dist/browser/signalr.min.js"></script>
<script>
    const chat = document.getElementById('chat');
    const typing = document.getElementById('typing');
    const input = document.getElementById('messageInput');
    const sendBtn = document.getElementById('sendBtn');

    let bufEl = null;

    const conn = new signalR.HubConnectionBuilder()
        .withUrl("/chathub")
        .withAutomaticReconnect()
        .build();

    conn.on("ReceiveUserEcho", (text) => {
        const div = document.createElement('div');
        div.className = "msg user";
        div.textContent = text;
        chat.appendChild(div);
        chat.scrollTop = chat.scrollHeight;
    });

    conn.on("ReceiveToken", (token) => {
        typing.style.display = 'block';
        if (!bufEl) {
            bufEl = document.createElement('div');
            bufEl.className = "msg ai";
            bufEl.textContent = "";
            chat.appendChild(bufEl);
        }
        bufEl.textContent += token;
        chat.scrollTop = chat.scrollHeight;
    });

    conn.on("CompleteMessage", () => {
        typing.style.display = 'none';
        bufEl = null;
    });

    async function start() {
        try { await conn.start(); }
        catch { setTimeout(start, 1500); }
    }
    start();

    async function send() {
        const text = input.value.trim();
        if (!text) return;
        input.value = "";
        bufEl = null;
        typing.style.display = 'block';
        await conn.invoke("SendMessage", text);
    }

    sendBtn.addEventListener('click', send);
    input.addEventListener('keydown', e => {
        if (e.key === 'Enter') send();
    });
</script>
