@model string
@{
    ViewData["Title"] = "CreateImageWithOpenAI";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card">
    <div class="card-body">
        <div class="d-flex align-items-center">
            <h5 class="mb-0">OpenAI ile Görsel Oluşturma</h5>
        </div>
        <form method="post">
            <div class="form-group">
                <label>Prompt</label>
                <input type="text" class="form-control" name="prompt" placeholder="Promptu giriniz" required />
            </div>
            <br />
            <button type="submit" class="btn btn-outline-primary mt-3">Görseli Oluştur</button>
        </form>

        @if (Model != null)
        {
           <h3>Oluşturulan Görsel</h3>            
           <img src="@Model" alt="Oluşturulan Görsel" style="max-width: 100%; height: auto;" />
        }
    </div>
</div>

