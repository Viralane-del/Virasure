@model AboutItem
@{
    ViewData["Title"] = "UpdateAboutItem";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card">
    <div class="card-body">
        <div class="d-flex align-items-center">
            <h5 class="mb-0">Yeni Hakkımızda Detay Yazısı Güncelleme</h5>
        </div>
        <form method="post">
            <input type="hidden" asp-for="AboutItemId" />
            <div class="form-group">
                <label>Detay</label>
                <input type="text" class="form-control" asp-for="Detail" placeholder="Detayı Giriniz" />
            </div>
            <button type="submit" class="btn btn-outline-primary mt-3">Güncelle</button>
        </form>
    </div>
</div>

