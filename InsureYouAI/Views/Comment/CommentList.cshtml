@model List<Comment>
@{
    ViewData["Title"] = "CommentList";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card">
    <div class="card-body">
        <div class="d-flex align-items-center">
            <h5 class="mb-0">Yorumlar Listesi</h5>
            <form class="ms-auto position-relative">
                <div class="position-absolute top-50 translate-middle-y search-icon px-3"><i class="bi bi-search"></i></div>
                <input class="form-control ps-5" type="text" placeholder="search">
            </form>
        </div>
        <div class="table-responsive mt-3">
            <table class="table align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Ad Soyad</th>
                        <th>Makale</th>
                        <th>Tarih</th>
                        <th>Durum</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.CommentID</td>
                            <td>@item.AppUser.Name @item.AppUser.Surname</td>
                            <td>@item.Article.Title</td>
                            <td>@item.CommentDate.ToString("dd-MMM-yyyy")</td>
                            <td>Durum</td>
                            <td>
                                <div class="table-actions d-flex align-items-center gap-3 fs-6">
                                    <a href="javascript:;" class="text-primary" data-bs-toggle="tooltip" data-bs-placement="bottom" title="Sitede Gör"><i class="bi bi-eye-fill"></i></a>
                                    <a href="/Comment/UpdateComment/@item.CommentID" class="text-success" data-bs-toggle="tooltip" data-bs-placement="bottom" title="Onayla"><i class="bi bi-checkmark-circle"></i></a>
                                    <a href="/Comment/DeleteComment/@item.CommentID" class="text-danger" data-bs-toggle="tooltip" data-bs-placement="bottom" title="Sil"><i class="bi bi-trash-fill"></i></a>
                                    <a href="/Comment/DeleteComment/@item.CommentID" class="text-warning" data-bs-toggle="tooltip" data-bs-placement="bottom" title="Yorumu Kaldır"><i class="bi bi-close"></i></a>
                                </div>
                            </td>
                        </tr>
                    }

                </tbody>
            </table>
            <a href="/Comment/CreateComment/" class="btn btn-outline-info">Yeni Yorum Ekle</a>
        </div>
    </div>
</div>

